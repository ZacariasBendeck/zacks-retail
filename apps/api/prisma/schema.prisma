  @@index([vendorCode], map: "purchase_order_legacy_vendor_code_idx")
  @@index([shipStore, orderDate], map: "purchase_order_legacy_ship_store_order_date_idx")
  @@map("purchase_order_legacy")
  @@schema("app")
}

/// Imported legacy purchase-order detail rows with the 18-wide ordered /
/// received quantity segments packed into int[] arrays.
model PurchaseOrderLegacyLine {
  poNumber        String              @map("po_number")
  purchaseOrder   PurchaseOrderLegacy @relation(fields: [poNumber], references: [poNumber], onDelete: Cascade, onUpdate: Cascade)
  skuCode         String              @map("sku_code") @db.VarChar(15)
  skuId           String?             @map("sku_id") @db.Uuid
  sku             Sku?                @relation(fields: [skuId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rowLabel        String              @default("") @map("row_label")
  segment         Int                 @db.SmallInt
  orderedQtys     Int[]               @map("ordered_qtys")
  receivedQtys    Int[]               @map("received_qtys")
  cost            Decimal?            @db.Decimal(12, 2)
  vendorCode      String?             @map("vendor_code")
  casePackCode    String?             @map("case_pack_code")
  caseMultiplier  Int?                @map("case_multiplier") @db.SmallInt
  dateLastChanged DateTime?           @map("date_last_changed")

  @@id([poNumber, skuCode, rowLabel, segment])
  @@index([skuCode], map: "purchase_order_legacy_line_sku_code_idx")
  @@index([skuId], map: "purchase_order_legacy_line_sku_id_idx")
  @@map("purchase_order_legacy_line")
  @@schema("app")
}

/// Native Zack's Retail purchase-order header. This is the Postgres write
/// surface for development-stage draft/operator POs and the cutover target for
/// operational purchasing. Legacy imported POs remain in purchase_order_legacy.
model PurchaseOrder {
  id                   String    @id @default(uuid()) @db.Uuid
  poNumber             String    @unique(map: "purchase_order_po_number_key") @map("po_number") @db.VarChar(32)
  billToStoreId        Int?      @map("bill_to_store_id") @db.SmallInt
  shipToStoreId        Int?      @map("ship_to_store_id") @db.SmallInt
  vendorCode           String    @map("vendor_code") @db.VarChar(4)
  orderType            String    @default("RO") @map("order_type") @db.VarChar(8)
  classification       String    @default("AT_ONCE") @db.VarChar(16)
  status               String    @default("DRAFT") @db.VarChar(32)
  origin               String    @default("MANUAL") @db.VarChar(32)
  originSourcePoId     String?   @map("origin_source_po_id") @db.Uuid
  confirmationNumber   String?   @map("confirmation_number")
  accountNumber        String?   @map("account_number")
  terms                String?
  shipVia              String?   @map("ship_via")
  backorderAllowed     Boolean   @default(false) @map("backorder_allowed")
  splitShipment        Boolean   @default(false) @map("split_shipment")
  programCode          String?   @map("program_code")
  storeLabelsOnReceive Boolean   @default(false) @map("store_labels_on_receive")
  buyer                String?
  comments             String?
  sourceCurrency       String    @default("HNL") @map("source_currency") @db.VarChar(3)
  fxRate               Decimal   @default(1) @map("fx_rate") @db.Decimal(18, 8)
  fxDate               DateTime  @default(now()) @map("fx_date") @db.Date
  incotermCode         String?   @map("incoterm_code") @db.VarChar(8)
  incotermPlace        String?   @map("incoterm_place")
  costBasis            String    @default("LANDED_LEGACY_HNL") @map("cost_basis") @db.VarChar(40)
  orderDate            DateTime  @default(now()) @map("order_date") @db.Timestamptz(6)
  shipDate             DateTime? @map("ship_date") @db.Timestamptz(6)
  plannedReceiptDate   DateTime? @map("planned_receipt_date") @db.Timestamptz(6)
  cancelDate           DateTime? @map("cancel_date") @db.Timestamptz(6)
  paymentDate          DateTime? @map("payment_date") @db.Timestamptz(6)
  supplierQuotationId  String?   @map("supplier_quotation_id") @db.Uuid
  supplierQuotation    SupplierQuotation? @relation(fields: [supplierQuotationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdBy            String    @map("created_by")
  submittedAt          DateTime? @map("submitted_at") @db.Timestamptz(6)
  closedAt             DateTime? @map("closed_at") @db.Timestamptz(6)
  cancellationReason   String?   @map("cancellation_reason")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  lines               PurchaseOrderLine[]
  receipts            PoReceipt[]
  statusHistory       PoStatusHistory[]
  matchingSetBuyPlans MatchingSetBuyPlan[]

  @@index([vendorCode, status], map: "purchase_order_vendor_status_idx")
  @@index([buyer, status], map: "purchase_order_buyer_status_idx")
  @@index([shipToStoreId, shipDate], map: "purchase_order_ship_store_ship_date_idx")
  @@index([plannedReceiptDate, status], map: "purchase_order_planned_receipt_status_idx")
  @@index([classification, status], map: "purchase_order_classification_status_idx")
  @@index([supplierQuotationId], map: "purchase_order_supplier_quotation_idx")
  @@map("purchase_order")
  @@schema("app")
}

/// Native PO line at SKU level. Per-size ordered quantities live in
/// purchase_order_line_size_cell; quantity_received is a denormalized rollup
/// maintained by the service from receipt-line ledger rows.
model PurchaseOrderLine {
  id                         String        @id @default(uuid()) @db.Uuid
  poId                       String        @map("po_id") @db.Uuid
  purchaseOrder              PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  skuId                      String        @map("sku_id") @db.Uuid
  sku                        Sku           @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lineSequence               Int           @map("line_sequence")
  casePackId                 String?       @map("case_pack_id")
  casePackMultiplier         Int?          @default(1) @map("case_pack_multiplier")
  retailPrice                Decimal?      @map("retail_price") @db.Decimal(12, 2)
  unitCost                   Decimal       @map("unit_cost") @db.Decimal(12, 2)
  sourceUnitCost             Decimal?      @map("source_unit_cost") @db.Decimal(14, 4)
  commercialUnitCostHnl      Decimal?      @map("commercial_unit_cost_hnl") @db.Decimal(14, 4)
  estimatedLandedUnitCostHnl Decimal?      @map("estimated_landed_unit_cost_hnl") @db.Decimal(14, 4)
  supplierQuotationLineId     String?       @map("supplier_quotation_line_id") @db.Uuid
  supplierQuotationLine       SupplierQuotationLine? @relation(fields: [supplierQuotationLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  quantityOrdered            Int           @map("quantity_ordered")
  quantityReceived           Int           @default(0) @map("quantity_received")
  writeBackToMaster          Boolean       @default(false) @map("write_back_to_master")
  createdAt                  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sizeCells            PurchaseOrderLineSizeCell[]
  receiptLines         PoReceiptLine[]
  matchingSetPlanLines MatchingSetBuyPlanLine[]
  importShipmentLines  ImportShipmentLine[]

  @@unique([poId, lineSequence], map: "purchase_order_line_sequence_key")
  @@index([poId], map: "purchase_order_line_po_id_idx")
  @@index([skuId], map: "purchase_order_line_sku_id_idx")
  @@index([supplierQuotationLineId], map: "purchase_order_line_supplier_quote_line_idx")
  @@map("purchase_order_line")
  @@schema("app")
}

model PurchaseOrderLineSizeCell {
  id              String            @id @default(uuid()) @db.Uuid
  poLineId        String            @map("po_line_id") @db.Uuid
  poLine          PurchaseOrderLine @relation(fields: [poLineId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  columnLabel     String            @default("") @map("column_label")
  rowLabel        String            @default("") @map("row_label")
  quantityOrdered Int               @map("quantity_ordered")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([poLineId, columnLabel, rowLabel], map: "purchase_order_line_size_cell_key")
  @@map("purchase_order_line_size_cell")
  @@schema("app")
}

/// Buyer-entered supplier quote header. This is the purchasing-side record
/// used before a style becomes a draft SKU or purchase-order line.
model SupplierQuotation {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteNumber       String    @unique(map: "supplier_quotation_quote_number_key") @map("quote_number") @db.VarChar(32)
  vendorCode        String    @map("vendor_code") @db.VarChar(4)
  vendor            Vendor    @relation(fields: [vendorCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  buyer             String?   @db.VarChar(120)
  season            String?   @db.VarChar(2)
  chainId           String?   @map("chain_id") @db.VarChar(64)
  chain             StoreGroup? @relation(fields: [chainId], references: [code], onDelete: SetNull, onUpdate: Cascade)
  sourceCurrency    String    @default("HNL") @map("source_currency") @db.VarChar(3)
  fxRate            Decimal   @default(1) @map("fx_rate") @db.Decimal(18, 8)
  fxDate            DateTime  @default(now()) @map("fx_date") @db.Date
  incotermCode      String?   @map("incoterm_code") @db.VarChar(8)
  incotermPlace     String?   @map("incoterm_place")
  paymentTerms      String?   @map("payment_terms")
  quoteDate         DateTime  @default(now()) @map("quote_date") @db.Date
  validUntil        DateTime? @map("valid_until") @db.Date
  leadTimeDays      Int?      @map("lead_time_days") @db.SmallInt
  status            String    @default("DRAFT") @db.VarChar(24)
  sourceDocumentRef String?   @map("source_document_ref")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy         String    @default("system") @map("created_by")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy         String    @default("system") @map("updated_by")

  lines          SupplierQuotationLine[]
  purchaseOrders PurchaseOrder[]

  @@index([vendorCode, status], map: "supplier_quotation_vendor_status_idx")
  @@index([buyer, status], map: "supplier_quotation_buyer_status_idx")
  @@index([chainId, quoteDate], map: "supplier_quotation_chain_quote_date_idx")
  @@index([status, updatedAt], map: "supplier_quotation_status_updated_idx")
  @@map("supplier_quotation")
  @@schema("app")
}

/// A quoted supplier style/color line. Accepted lines can become DRAFT SKUs
/// and normal purchase-order lines while preserving quote traceability.
model SupplierQuotationLine {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationId                String    @map("quotation_id") @db.Uuid
  quotation                  SupplierQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  lineSequence               Int       @map("line_sequence")
  linkedSkuId                String?   @map("linked_sku_id") @db.Uuid
  linkedSku                  Sku?      @relation(fields: [linkedSkuId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  supplierStyle              String    @map("supplier_style")
  supplierColorCode          String?   @map("supplier_color_code")
  supplierColorName          String?   @map("supplier_color_name")
  description                String?
  familyCode                 String?   @map("family_code")
  family                     ProductFamily? @relation(fields: [familyCode], references: [code], onDelete: SetNull, onUpdate: Cascade)
  categoryNumber             Int?      @map("category_number") @db.SmallInt
  category                   TaxonomyCategory? @relation(fields: [categoryNumber], references: [number], onDelete: SetNull, onUpdate: Cascade)
  colorFamilyValueId         Int?      @map("color_family_value_id") @db.SmallInt
  colorFamilyValue           AttributeValue? @relation("SupplierQuotationColorFamily", fields: [colorFamilyValueId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  materialValueId            Int?      @map("material_value_id") @db.SmallInt
  materialValue              AttributeValue? @relation("SupplierQuotationMaterial", fields: [materialValueId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  styleElementValueId        Int?      @map("style_element_value_id") @db.SmallInt
  styleElementValue          AttributeValue? @relation("SupplierQuotationStyleElement", fields: [styleElementValueId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  keywords                   String?
  imageUrl                   String?   @map("image_url")
  moqQty                     Int?      @map("moq_qty")
  quotedQty                  Int?      @map("quoted_qty")
  unitCost                   Decimal   @map("unit_cost") @db.Decimal(14, 4)
  estimatedLandedUnitCostHnl Decimal?  @map("estimated_landed_unit_cost_hnl") @db.Decimal(14, 4)
  targetRetailHnl            Decimal?  @map("target_retail_hnl") @db.Decimal(12, 2)
  marginPct                  Decimal?  @map("margin_pct") @db.Decimal(7, 4)
  plannedReceiptDate         DateTime? @map("planned_receipt_date") @db.Timestamptz(6)
  decisionStatus             String    @default("NEW") @map("decision_status") @db.VarChar(24)
  decisionReason             String?   @map("decision_reason")
  decisionAt                 DateTime? @map("decision_at") @db.Timestamptz(6)
  decisionBy                 String?   @map("decision_by")
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy                  String    @default("system") @map("created_by")
  updatedAt                  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy                  String    @default("system") @map("updated_by")

  sourceRelations SupplierQuotationLineRelation[] @relation("SourceQuotationLineRelations")
  targetRelations SupplierQuotationLineRelation[] @relation("TargetQuotationLineRelations")
  purchaseOrderLines PurchaseOrderLine[]

  @@unique([quotationId, lineSequence], map: "supplier_quotation_line_sequence_key")
  @@index([quotationId, decisionStatus], map: "supplier_quotation_line_quote_decision_idx")
  @@index([linkedSkuId], map: "supplier_quotation_line_sku_idx")
  @@index([familyCode, categoryNumber], map: "supplier_quotation_line_family_category_idx")
  @@index([supplierStyle], map: "supplier_quotation_line_supplier_style_idx")
  @@map("supplier_quotation_line")
  @@schema("app")
}

/// Manual buyer links from a quoted line to another quote, existing SKU, or
/// matching set. Automatic similarity suggestions are calculated, not stored.
model SupplierQuotationLineRelation {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceLineId             String    @map("source_line_id") @db.Uuid
  sourceLine               SupplierQuotationLine @relation("SourceQuotationLineRelations", fields: [sourceLineId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  relationType             String    @map("relation_type") @db.VarChar(24)
  targetType               String    @map("target_type") @db.VarChar(24)
  targetSkuId              String?   @map("target_sku_id") @db.Uuid
  targetSku                Sku?      @relation(fields: [targetSkuId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  targetMatchingSetId      String?   @map("target_matching_set_id") @db.Uuid
  targetMatchingSet        MatchingSet? @relation(fields: [targetMatchingSetId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  targetQuotationLineId    String?   @map("target_quotation_line_id") @db.Uuid
  targetQuotationLine      SupplierQuotationLine? @relation("TargetQuotationLineRelations", fields: [targetQuotationLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  note                     String?
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy                String    @default("system") @map("created_by")

  @@index([sourceLineId], map: "supplier_quotation_line_relation_source_idx")
  @@index([targetSkuId], map: "supplier_quotation_line_relation_sku_idx")
  @@index([targetMatchingSetId], map: "supplier_quotation_line_relation_matching_set_idx")
  @@index([targetQuotationLineId], map: "supplier_quotation_line_relation_quote_line_idx")
  @@map("supplier_quotation_line_relation")
  @@schema("app")
}

model PoReceipt {
  id                  String        @id @default(uuid()) @db.Uuid
  poId                String        @map("po_id") @db.Uuid
  purchaseOrder       PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  receivedAtStoreId   Int?          @map("received_at_store_id") @db.SmallInt
  receivedBy          String        @map("received_by")
  referenceNumber     String?       @map("reference_number")
  idempotencyKey      String?       @unique(map: "po_receipt_idempotency_key") @map("idempotency_key")
  asnCartonId         String?       @map("asn_carton_id") @db.Uuid
  mode                String        @default("MANUAL") @db.VarChar(16)
  discountPercent     Decimal?      @default(0) @map("discount_percent") @db.Decimal(5, 2)
  freightEach         Decimal?      @default(0) @map("freight_each") @db.Decimal(12, 2)
  receivedAt          DateTime      @default(now()) @map("received_at") @db.Timestamptz(6)
  reversalOfReceiptId String?       @map("reversal_of_receipt_id") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

