  rowLabel               String              @default("") @map("row_label")
  quantityReceived       Int                 @map("quantity_received")
  effectiveUnitCost      Decimal             @map("effective_unit_cost") @db.Decimal(12, 2)
  discrepancyReason      String?             @map("discrepancy_reason")
  auditReference         String?             @map("audit_reference")
  movementId             String?             @map("movement_id") @db.Uuid
  importShipmentId       String?             @map("import_shipment_id") @db.Uuid
  importShipment         ImportShipment?     @relation(fields: [importShipmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  importInvoiceLineId    String?             @map("import_invoice_line_id") @db.Uuid
  importInvoiceLine      ImportInvoiceLine?  @relation(fields: [importInvoiceLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  importShipmentLineId   String?             @map("import_shipment_line_id") @db.Uuid
  importShipmentLine     ImportShipmentLine? @relation(fields: [importShipmentLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
