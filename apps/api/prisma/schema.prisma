// SKU lifecycle — net-new SKUs created in Zack's Retail.
//
// Spec: docs/dev/plans/http-localhost-3000-inventory-skus-new-i-piped-galaxy.md
//       §"Phase 5 — SKU lifecycle (DRAFT → ACTIVE → DISCONTINUED)"
//
// State machine:
//   DRAFT        — provisional_code set, final `code` NULL, all fields editable.
//                  Receipt into WH allowed; allocate/barcode/POS/ecommerce blocked.
//   ACTIVE       — finalize flipped the row. `code` populated, rename blocked,
//                  all downstream ops unlocked.
//   DISCONTINUED — merged-into-another-SKU or retired. Read-only.
//
// Legacy RICS SKUs are imported into `app.sku` as `source='rics'`. The write
// path is `app.sku` only.
// ─────────────────────────────────────────────────────────────────────────

/// A SKU created in Zack's Retail (net-new). Lifecycle-managed.
/// The `sku_code_matches_state` check constraint enforces:
///   state=DRAFT  → code IS NULL
///   state≠DRAFT  → code IS NOT NULL
/// The service layer owns the transitions (see skuLifecycleService).
model Sku {
  id              String  @id @default(uuid()) @db.Uuid
  provisionalCode String  @map("provisional_code") @db.VarChar(32)
  code            String? @unique(map: "sku_code_key") @db.VarChar(15)
  skuState        String  @default("DRAFT") @map("sku_state")

  familyCode     String?        @map("family_code")
  family         ProductFamily? @relation(fields: [familyCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  categoryNumber Int?           @map("category_number")
  vendorId       String?        @map("vendor_id")
  vendorSku      String?        @map("vendor_sku")
  brandId        Int?           @map("brand_id")

  descriptionRics String? @map("description_rics")
  descriptionWeb  String? @map("description_web")
  comment         String?
  keywords        String?

  listPrice        Decimal? @map("list_price") @db.Decimal(12, 2)
  retailPrice      Decimal? @map("retail_price") @db.Decimal(12, 2)
  markDownPrice1   Decimal? @map("mark_down_price1") @db.Decimal(12, 2)
  markDownPrice2   Decimal? @map("mark_down_price2") @db.Decimal(12, 2)
  currentCost      Decimal? @map("current_cost") @db.Decimal(12, 2)
  currentPriceSlot String?  @map("current_price_slot")

  sizeType        Int?     @map("size_type") @db.SmallInt
  styleColor      String?  @map("style_color")
  season          String?  @db.VarChar(2)
  location        String?
  labelCode       String?  @map("label_code")
  colorCode       String?  @map("color_code")
  groupCode       String?  @map("group_code")
  pictureFileName String?  @map("picture_file_name")
  manufacturer    String?
  coupon          Boolean  @default(false)
  orderMultiple   Int?     @map("order_multiple") @db.SmallInt
  orderUom        String?  @map("order_uom")
  perks           Decimal? @db.Decimal(12, 2)
  discountCode    String?  @map("discount_code")

  activatedAt    DateTime? @map("activated_at")
  activatedBy    String?   @map("activated_by")
  discontinuedAt DateTime? @map("discontinued_at")
  discontinuedBy String?   @map("discontinued_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  createdBy      String    @map("created_by")
  updatedAt      DateTime? @map("updated_at")

  /// Transitional — carries legacy form-attribute IDs (colorId, shoeTypeId, …).
  /// Phase 4 replaces this with proper dimension assignments.
  legacyAttrs Json? @map("legacy_attrs")

  /// Provenance: 'app' = operator-created via POST /sku-drafts. 'rics' =
  /// imported from legacy RICS CSV artifacts into `app.sku`.
  source           String    @default("app")
  ricsLastSyncedAt DateTime? @map("rics_last_synced_at")
  ricsStatus       String?   @map("rics_status") @db.Char(1)

  activity                  SkuActivity[]
  sizes                     SkuSize[]
  inventory                 Inventory[]
  auditLog                  InventoryAuditLog[]
  stockLevels               StockLevel[]
  stockMovements            StockMovement[]
  stockCostEvents           StockCostEvent[]
  stockCostBalances         StockCostBalance[]
  replenishmentTargets      ReplenishmentTarget[]
  inventorySalesCells       InventorySalesCell[]
  upcs                      SkuUpc[]
  futurePriceChanges        FuturePriceChange[]
  purchaseOrderLines        PurchaseOrderLine[]
  poReceiptLines            PoReceiptLine[]
  purchaseOrderLegacyLines  PurchaseOrderLegacyLine[]
  matchingSetBuyPlanLines   MatchingSetBuyPlanLine[]
  manualReceipts            ManualReceipt[]
  manualReturns             ManualReturn[]
  transferLines             TransferLine[]
  inventoryAdjustmentLines  InventoryAdjustmentLine[]
  inventoryHistorySnapshots InventoryHistorySnapshot[]
  matchingSetMembers        MatchingSetMember[]
  importCostBuildOutputs    ImportCostBuild[]
  supplierQuotationLines    SupplierQuotationLine[]
  supplierQuotationRelations SupplierQuotationLineRelation[]
  replacementsFromThis      SkuReplacement[] @relation("SkuReplacementOld")
  replacementsToThis        SkuReplacement[] @relation("SkuReplacementNew")

  @@unique([provisionalCode], map: "sku_provisional_code_key")
  @@index([skuState, familyCode], map: "sku_state_family_idx")
  @@index([vendorId], map: "sku_vendor_idx")
  @@index([categoryNumber], map: "sku_category_idx")
  @@index([createdAt], map: "sku_created_at_idx")
  @@index([source, skuState], map: "sku_source_state_idx")
  @@map("sku")
  @@schema("app")
}

/// Catalog of Product matching-set types such as suit, bikini, pajama, and
/// coordinate. Matching sets are app-owned Product relationships.
model MatchingSetType {
  code          String            @id
  labelEs       String            @map("label_es")
  descriptionEs String?           @map("description_es")
  sortOrder     Int               @default(0) @map("sort_order") @db.SmallInt
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles         MatchingSetRole[]
  sets          MatchingSet[]

  @@map("matching_set_type")
  @@schema("app")
}

/// Role catalog scoped to a matching-set type. Required defaults drive the
/// first-pass gap detection used by buyer/admin screens.
model MatchingSetRole {
  setTypeCode     String          @map("set_type_code")
  code            String
  labelEs         String          @map("label_es")
  sortOrder       Int             @default(0) @map("sort_order") @db.SmallInt
  requiredDefault Boolean         @default(false) @map("required_default")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  setType         MatchingSetType @relation(fields: [setTypeCode], references: [code], onDelete: Cascade, onUpdate: Cascade)

  @@id([setTypeCode, code])
  @@map("matching_set_role")
  @@schema("app")
}

/// Header record for a conjunto / matching set. Members remain independently
/// sellable SKUs but are analyzed and maintained together.
model MatchingSet {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String               @unique(map: "matching_set_code_key")
  displayName      String?              @map("display_name")
  setTypeCode      String               @map("set_type_code")
  setType          MatchingSetType      @relation(fields: [setTypeCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  descriptionEs    String?              @map("description_es")
  vendorId         String?              @map("vendor_id") @db.VarChar(4)
  vendor           Vendor?              @relation(fields: [vendorId], references: [code], onDelete: SetNull, onUpdate: Cascade)
  vendorStyle      String?              @map("vendor_style")
  materialCode     String?              @map("material_code")
  materialLabel    String?              @map("material_label")
  sharedColorCode  String?              @map("shared_color_code")
  sharedColorLabel String?              @map("shared_color_label")
  season           String?              @db.VarChar(2)
  chainId          String?              @map("chain_id") @db.VarChar(64)
  chain            StoreGroup?          @relation(fields: [chainId], references: [code], onDelete: SetNull, onUpdate: Cascade)
  sellMode         String               @default("separates") @map("sell_mode") @db.VarChar(24)
  planningActive   Boolean              @default(true) @map("planning_active")
  notes            String?
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy        String               @default("system") @map("created_by")
  updatedAt        DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy        String               @default("system") @map("updated_by")
  members          MatchingSetMember[]
  buyPlans         MatchingSetBuyPlan[]
  supplierQuotationRelations SupplierQuotationLineRelation[]

  @@index([setTypeCode], map: "matching_set_type_idx")
  @@index([vendorId], map: "matching_set_vendor_idx")
  @@index([vendorId, vendorStyle, sharedColorCode, season], map: "matching_set_lookup_idx")
  @@index([chainId], map: "matching_set_chain_idx")
  @@index([active, updatedAt], map: "matching_set_active_idx")
  @@map("matching_set")
  @@schema("app")
}

/// Member row linking a Product matching set to an app.sku UUID.
model MatchingSetMember {
  setId         String                       @map("set_id") @db.Uuid
  skuId         String                       @map("sku_id") @db.Uuid
  roleCode      String                       @map("role_code")
  isPrimary     Boolean                      @default(false) @map("is_primary")
  quantityRatio Decimal                      @default(1) @map("quantity_ratio") @db.Decimal(8, 3)
  addedAt       DateTime                     @default(now()) @map("added_at") @db.Timestamptz(6)
  addedBy       String                       @default("system") @map("added_by")
  updatedAt     DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy     String                       @default("system") @map("updated_by")
  set           MatchingSet                  @relation(fields: [setId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sku           Sku                          @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sizeCurves    MatchingSetMemberSizeCurve[]
  buyPlanLines  MatchingSetBuyPlanLine[]

  @@id([setId, skuId])
  @@index([skuId], map: "matching_set_member_sku_idx")
  @@index([roleCode], map: "matching_set_member_role_idx")
  @@map("matching_set_member")
  @@schema("app")
}

/// State-transition audit log. Written by skuLifecycleService — no DB trigger,
/// because we want the service to own the who/why context (actor, reason).
/// Optional role/size profile used to split a matching-set buy recommendation
/// into purchase-order size cells. Percent values are normalized by service
/// code, so buyers can enter rough curves and still get a valid split.
model MatchingSetMemberSizeCurve {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  setId       String            @map("set_id") @db.Uuid
  skuId       String            @map("sku_id") @db.Uuid
  member      MatchingSetMember @relation(fields: [setId, skuId], references: [setId, skuId], onDelete: Cascade, onUpdate: Cascade)
  chainId     String?           @map("chain_id") @db.VarChar(64)
  chain       StoreGroup?       @relation(fields: [chainId], references: [code], onDelete: SetNull, onUpdate: Cascade)
  storeId     Int?              @map("store_id") @db.SmallInt
  sizeLabel   String            @map("size_label")
  columnLabel String            @default("") @map("column_label")
  rowLabel    String            @default("") @map("row_label")
  ratioPct    Decimal           @map("ratio_pct") @db.Decimal(7, 4)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy   String            @default("system") @map("created_by")
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy   String            @default("system") @map("updated_by")

  @@index([chainId], map: "matching_set_member_size_curve_chain_idx")
  @@map("matching_set_member_size_curve")
  @@schema("app")
}

/// Saved recommendation generated from a matching set. It is a planning
/// artifact until the buyer turns it into a normal purchase order.
model MatchingSetBuyPlan {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  setId            String                   @map("set_id") @db.Uuid
  set              MatchingSet              @relation(fields: [setId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  chainId          String?                  @map("chain_id") @db.VarChar(64)
  chain            StoreGroup?              @relation(fields: [chainId], references: [code], onDelete: SetNull, onUpdate: Cascade)
  receiptMonth     String                   @map("receipt_month") @db.VarChar(7)
  horizonWeeks     Int                      @default(13) @map("horizon_weeks") @db.SmallInt
  targetCoverWeeks Int                      @default(8) @map("target_cover_weeks") @db.SmallInt
  status           String                   @default("draft") @db.VarChar(24)
  generatedPoId    String?                  @map("generated_po_id") @db.Uuid
  generatedPo      PurchaseOrder?           @relation(fields: [generatedPoId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  otbStatus        String?                  @map("otb_status") @db.VarChar(24)
  otbSnapshotJson  Json?                    @map("otb_snapshot_json")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy        String                   @default("system") @map("created_by")
  updatedAt        DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy        String                   @default("system") @map("updated_by")
  lines            MatchingSetBuyPlanLine[]

  @@index([setId, createdAt(sort: Desc)], map: "matching_set_buy_plan_set_created_idx")
  @@index([chainId, receiptMonth], map: "matching_set_buy_plan_chain_month_idx")
  @@index([generatedPoId], map: "matching_set_buy_plan_po_idx")
  @@map("matching_set_buy_plan")
  @@schema("app")
}

/// Recommendation line at SKU x role x size grain. PO creation explodes these
