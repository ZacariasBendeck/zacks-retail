  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([poId, createdAt], map: "po_status_history_po_created_at_idx")
  @@map("po_status_history")
  @@schema("app")
}

/// Imported legacy ASN carton headers from RICS ASN tables.
