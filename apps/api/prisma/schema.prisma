model MatchingSetBuyPlanLine {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId           String             @map("plan_id") @db.Uuid
  plan             MatchingSetBuyPlan @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  setId            String             @map("set_id") @db.Uuid
  skuId            String             @map("sku_id") @db.Uuid
  member           MatchingSetMember  @relation(fields: [setId, skuId], references: [setId, skuId], onDelete: Restrict, onUpdate: Cascade)
