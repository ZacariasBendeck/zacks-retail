  retailPrice      Decimal?  @map("retail_price") @db.Decimal(12, 2)
  markDownPrice1   Decimal?  @map("mark_down_price1") @db.Decimal(12, 2)
  markDownPrice2   Decimal?  @map("mark_down_price2") @db.Decimal(12, 2)
  currentPriceSlot String?   @map("current_price_slot")
  overSizeAmount   Decimal?  @map("over_size_amount") @db.Decimal(12, 2)
  perks            Decimal?  @db.Decimal(12, 2)
  source           String    @default("RICS_IMPORT")
  dateLastChanged  DateTime? @map("date_last_changed")

  @@index([skuCode, effectiveAt], map: "future_price_change_sku_effective_at_idx")
  @@index([storeId, effectiveAt], map: "future_price_change_store_effective_at_idx")
  @@map("future_price_change")
  @@schema("app")
}

/// Imported legacy purchase-order headers from RIPOMAS.MDB. Preserves the
/// source rowset in Postgres until the full purchasing schema is promoted.
model PurchaseOrderLegacy {
  poNumber        String                    @id @map("po_number")
  billStore       Int?                      @map("bill_store") @db.SmallInt
  shipStore       Int?                      @map("ship_store") @db.SmallInt
  vendorCode      String?                   @map("vendor_code")
  confirmation    String?
  account         String?
  terms           String?
  shipVia         String?                   @map("ship_via")
  backOrder       Boolean                   @default(false) @map("back_order")
  splitShipment   Boolean                   @default(false) @map("split_shipment")
  orderDate       DateTime?                 @map("order_date")
  dueDate         DateTime?                 @map("due_date")
  cancelDate      DateTime?                 @map("cancel_date")
  paymentDate     DateTime?                 @map("payment_date")
  lastReceivedAt  DateTime?                 @map("last_received_at")
  comment         String?
  exportFlag      Boolean                   @default(false) @map("export_flag")
  exportComment   String?                   @map("export_comment")
  orderType       String?                   @map("order_type")
  releaseDt       String?                   @map("release_dt")
  department      String?
  buyer           String?
  notBefore       DateTime?                 @map("not_before")
  notAfter        DateTime?                 @map("not_after")
  shipCode        String?                   @map("ship_code")
  carrier         String?
  termsPeriod     String?                   @map("terms_period")
  termsDay        String?                   @map("terms_day")
  current         Boolean?
