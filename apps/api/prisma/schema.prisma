  audienceKey         String?                    @unique @map("audience_key")
  name                String
  description         String?
  requestedBy         String?                    @map("requested_by") @db.Uuid
  request             Json
  totalCandidates     Int                        @default(0) @map("total_candidates")
  eligibleCustomers   Int                        @default(0) @map("eligible_customers")
  holdoutCustomers    Int                        @default(0) @map("holdout_customers")
  activationCustomers Int                        @default(0) @map("activation_customers")
  status              String
  createdAt           DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt           DateTime?                  @map("expires_at") @db.Timestamptz(6)
  errorMessage        String?                    @map("error_message")
  members             ActivationAudienceMember[]

  @@map("activation_audiences")
  @@schema("app")
}

model ActivationAudienceMember {
  audienceId         String             @map("audience_id") @db.Uuid
  customerId         String             @map("customer_id") @db.Uuid
  audience           ActivationAudience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  treatmentGroup     String             @map("treatment_group")
  suppressionReasons Json?              @map("suppression_reasons")
  segmentIds         String[]           @map("segment_ids") @db.Uuid
  segmentVersionIds  String[]           @map("segment_version_ids") @db.Uuid
  score              Decimal?           @db.Decimal(10, 4)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([audienceId, customerId])
  @@index([customerId], map: "idx_activation_audience_members_customer")
  @@index([audienceId, treatmentGroup], map: "idx_activation_audience_members_group")
  @@map("activation_audience_members")
  @@schema("app")
}

model CustomerSegmentAuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  eventType   String   @map("event_type")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([entityType, entityId, occurredAt(sort: Desc)], map: "idx_customer_segment_audit_entity")
  @@index([eventType, occurredAt(sort: Desc)], map: "idx_customer_segment_audit_event")
  @@map("customer_segment_audit_log")
  @@schema("app")
}

/// crm module â€” Customer master. Mirrors the RICS Mailing List entry (Ch. 9 p. 117).
/// Slim Stage 1 subset per docs/modules/crm.md; loyalty / quotes / mail detail
/// tables land later. `account_number` is the RICS convention (phone with no
/// formatting when not supplied â€” see `normalizePhoneForAccount` in the service).
model Customer {
  id                        String    @id @default(uuid())
  accountNumber             String    @unique @map("account_number")
  phoneE164                 String?   @map("phone_e164")
  firstName                 String?   @map("first_name")
  lastName                  String?   @map("last_name")
  displayName               String    @map("display_name")
  email                     String?
  addressLine1              String?   @map("address_line1")
  addressLine2              String?   @map("address_line2")
  city                      String?
  stateRegion               String?   @map("state_region")
  postalCode                String?   @map("postal_code")
  country                   String?
  /// Dollars (HNL). Null = no credit limit configured.
  creditLimit               Decimal?  @map("credit_limit") @db.Decimal(12, 2)
  alertFlag                 Boolean   @default(false) @map("alert_flag")
  alertMessage              String?   @map("alert_message")
  comments                  String?
  /// Period-to-date / year-to-date / two-to-date counters, updated by the
  /// sales-pos ticket close. Stored as integers: cents for money, units for qty.
  ptdQty                    Int       @default(0) @map("ptd_qty")
  ptdSalesCents             Int       @default(0) @map("ptd_sales_cents")
  ytdQty                    Int       @default(0) @map("ytd_qty")
  ytdSalesCents             Int       @default(0) @map("ytd_sales_cents")
  ttdQty                    Int       @default(0) @map("ttd_qty")
  ttdSalesCents             Int       @default(0) @map("ttd_sales_cents")
  lastYearSalesCents        Int       @default(0) @map("last_year_sales_cents")
  dateAdded                 DateTime  @default(now()) @map("date_added")
  dateOfLastPurchase        DateTime? @map("date_of_last_purchase")
  /// Cached A/R balance + store-credit projections. Stage 1 placeholders until
  /// accounts-receivable and customer-transactions wire their live sources.
  lastKnownArBalanceCents   Int       @default(0) @map("last_known_ar_balance_cents")
  arBalanceAsOf             DateTime? @map("ar_balance_as_of")
  lastKnownStoreCreditCents Int       @default(0) @map("last_known_store_credit_cents")
  storeCreditAsOf           DateTime? @map("store_credit_as_of")
  /// Free-form operator extensions; shape is caller-defined.
  extraFieldsJson           Json?     @map("extra_fields_json")
  marketingOptIn            Boolean   @default(false) @map("marketing_opt_in")
  active                    Boolean   @default(true)
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  familyMembers FamilyMember[]

  @@index([phoneE164], map: "customers_phone_idx")
  @@index([lastName, firstName], map: "customers_last_first_idx")
  @@index([postalCode], map: "customers_postal_idx")
  @@map("customers")
  @@schema("app")
}

/// crm module — Family Member (RICS p. 118). A household sub-account under a
/// Customer (spouse, children, etc.). `code` is unique per customer and
/// typically a short label the operator types at POS ("WIFE", "SON1", …).
model FamilyMember {
  id              String   @id @default(uuid())
  customerId      String   @map("customer_id")
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  code            String
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  /// M / F / C (child). Narrowed at the service layer; the column is plain text
  /// so future values don't require a migration.
  gender          String?
  /// ISO date string; kept as text for the same partial-date tolerance RICS had.
  birthday        String?
  comments        String?
  alertFlag       Boolean  @default(false) @map("alert_flag")
  alertMessage    String?  @map("alert_message")
  extraFieldsJson Json?    @map("extra_fields_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([customerId, code])
  @@index([customerId], map: "customer_family_members_customer_idx")
  @@map("customer_family_members")
  @@schema("app")
}

// ─── Taxonomy (app-owned reference data) ────────────────────────────────────
//
// 1:1 port of the eight RICS taxonomy tables that had editable-on-Windows MDB
// write paths. Reads and writes both live here now. RICS column names are
// preserved under the @map aliases so a rehearsal comparison against legacy CSV
// extracts stays byte-for-byte easy. Legacy MDB write paths under
// apps/api/src/repositories/rics/ are deleted in the same change.
//
// Range relationships (Department↔Category, Sector↔Department) remain
// implicit — encoded as [beg, end] bounds per RICS p. 144-145, not FKs —
// so every downstream report that walks the range keeps working.

/// RICS Departments (RIDEPT.MDB / Departments). Number is 1..99 (RICS p. 144).
model TaxonomyDepartment {
  number          Int      @id @map("number") @db.SmallInt
  description     String   @map("desc")
  begCateg        Int      @map("beg_categ") @db.SmallInt
  endCateg        Int      @map("end_categ") @db.SmallInt
  dateLastChanged DateTime @default(now()) @updatedAt @map("date_last_changed")

  @@index([begCateg, endCateg], map: "taxonomy_department_categ_range_idx")
  @@map("taxonomy_department")
  @@schema("app")
}

/// RICS Categories (RICATEG.MDB / Categories). Number is 1..999 (RICS p. 145).
/// No FK to Department — the implicit link is `begCateg <= number <= endCateg`.
model TaxonomyCategory {
  number          Int      @id @map("number") @db.SmallInt
  description     String   @map("desc")
  dateLastChanged DateTime @default(now()) @updatedAt @map("date_last_changed")
  buyerAssignments CategoryBuyerAssignment[]
  supplierQuotationLines SupplierQuotationLine[]

  @@map("taxonomy_category")
  @@schema("app")
}

/// RICS Groups (RIGROUP.MDB / GroupCodes). User-editable short code (text pk).
model TaxonomyGroup {
  code            String   @id @map("code")
  description     String   @map("desc")
  dateLastChanged DateTime @default(now()) @updatedAt @map("date_last_changed")

  @@map("taxonomy_group")
  @@schema("app")
}

/// RICS Keywords (RIGROUP.MDB / Keywords). Free-text tag attached to SKUs.
model TaxonomyKeyword {
  keyword         String   @id @map("keyword")
  description     String   @map("desc")
  dateLastChanged DateTime @default(now()) @updatedAt @map("date_last_changed")

  @@map("taxonomy_keyword")
  @@schema("app")
}

/// RICS Sectors (RIDEPT.MDB / Sectors). Range-based grouping of Departments
/// via [begDept, endDept] (RICS p. 143).
model TaxonomySector {
  number          Int      @id @map("number") @db.SmallInt
  description     String   @map("desc")
  begDept         Int      @map("beg_dept") @db.SmallInt
  endDept         Int      @map("end_dept") @db.SmallInt
  dateLastChanged DateTime @default(now()) @updatedAt @map("date_last_changed")

  @@index([begDept, endDept], map: "taxonomy_sector_dept_range_idx")
  @@map("taxonomy_sector")
  @@schema("app")
}

/// RICS Return Codes (RIRETURN.MDB / ReturnCodes). POS return-reason lookup.
model TaxonomyReturnCode {
  code            Int      @id @map("code") @db.SmallInt
  description     String   @map("desc")
  trackable       Boolean  @default(false) @map("trackable")
  dateLastChanged DateTime @default(now()) @updatedAt @map("date_last_changed")

  @@map("taxonomy_return_code")
  @@schema("app")
}

/// RICS Promotion Codes (RIGROUP.MDB / MarketingCode). Ad-hoc promo metadata.
model TaxonomyPromotionCode {
  code            String    @id @map("code")
  description     String    @map("description")
  date            DateTime? @map("date")
  pieces          Int?      @map("pieces")
  cost            Decimal?  @map("cost") @db.Decimal(12, 2)
  dateLastChanged DateTime  @default(now()) @updatedAt @map("date_last_changed")

  @@map("taxonomy_promotion_code")
  @@schema("app")
}

/// RICS Size Types (RISIZE.MDB / SizeTypes). Defines the column×row grid shape
/// used by every SKU for sizing. In RICS these were stored as a single wide
/// row with 54 Columns_NN + 27 Rows_NN slots; here they are native Postgres
/// text arrays. Writes are a single row update; no segment packing.
model TaxonomySizeType {
  code              Int      @id @map("code") @db.SmallInt
  description       String   @map("desc")
  columnDescription String   @default("") @map("column_desc")
  rowDescription    String   @default("") @map("row_desc")
  tableType         String?  @map("table_type")
  /// Non-blank column labels in order. Physical length drives maxColumns.
  columns           String[] @default([]) @map("columns")
  /// Non-blank row labels in order. Physical length drives maxRows.
  rows              String[] @default([]) @map("rows")
  /// Preserved for UI parity — derived from `columns.length` but persisted so
  /// an empty-slot intent ("I have 10 column slots, 3 filled") is recoverable.
  maxColumns        Int      @default(0) @map("max_columns") @db.SmallInt
  maxRows           Int      @default(0) @map("max_rows") @db.SmallInt
  dateLastChanged   DateTime @default(now()) @updatedAt @map("date_last_changed")

  @@map("taxonomy_size_type")
  @@schema("app")
}

/// Cash-register entity under a store. The browser POS binds an open shift to
/// exactly one register so cashier state can recover across reloads.
model PosRegister {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   Int        @map("store_id") @db.SmallInt
  code      String     @db.VarChar(20)
  label     String     @db.VarChar(80)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  shifts    PosShift[]

  @@unique([storeId, code], map: "pos_register_store_code_key")
  @@index([storeId, active], map: "pos_register_store_active_idx")
  @@map("pos_register")
  @@schema("app")
}

/// Store-scoped tender catalog used by Enter Sales and close-batch counts.
model PosTenderType {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId         Int               @map("store_id") @db.SmallInt
  code            String            @db.VarChar(10)
  label           String            @db.VarChar(80)
  kind            String            @db.VarChar(32)
  requiresAccount Boolean           @default(false) @map("requires_account")
  openDrawer      Boolean           @default(false) @map("open_drawer")
  active          Boolean           @default(true)
  sortOrder       Int               @default(0) @map("sort_order")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenders         PosTicketTender[]

  @@unique([storeId, code], map: "pos_tender_type_store_code_key")
  @@index([storeId, active, sortOrder], map: "pos_tender_type_store_active_sort_idx")
  @@map("pos_tender_type")
  @@schema("app")
}

/// Store-scoped payout categories. `sales-pos` owns the runtime until
/// `store-ops` grows a dedicated admin screen.
model PosPayoutCategory {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   Int         @map("store_id") @db.SmallInt
  code      String      @db.VarChar(20)
  label     String      @db.VarChar(80)
  active    Boolean     @default(true)
  sortOrder Int         @default(0) @map("sort_order")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  payouts   PosPayout[]

  @@unique([storeId, code], map: "pos_payout_category_store_code_key")
  @@index([storeId, active, sortOrder], map: "pos_payout_category_store_active_sort_idx")
  @@map("pos_payout_category")
  @@schema("app")
}

/// Register shift / "batch of sales" header.
model PosShift {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId           Int         @map("store_id") @db.SmallInt
  registerId        String      @map("register_id") @db.Uuid
  register          PosRegister @relation(fields: [registerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  registerCode      String      @map("register_code") @db.VarChar(20)
  businessDate      DateTime    @map("business_date") @db.Date
  openedByUserId    String      @map("opened_by_user_id") @db.Uuid
  openedByName      String      @map("opened_by_name") @db.VarChar(120)
  openingCashFloat  Decimal     @default(0) @map("opening_cash_float") @db.Decimal(12, 2)
  status            String      @default("OPEN") @db.VarChar(20)
  lastTicketNumber  Int         @default(0) @map("last_ticket_number")
  openedAt          DateTime    @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt          DateTime?   @map("closed_at") @db.Timestamptz(6)
  closedByUserId    String?     @map("closed_by_user_id") @db.Uuid
  closedByName      String?     @map("closed_by_name") @db.VarChar(120)
  expectedCashTotal Decimal?    @map("expected_cash_total") @db.Decimal(12, 2)
  actualCashTotal   Decimal?    @map("actual_cash_total") @db.Decimal(12, 2)
  overShortAmount   Decimal?    @map("over_short_amount") @db.Decimal(12, 2)
  countSummaryJson  Json?       @map("count_summary_json")
  notes             String?
  postedAt          DateTime?   @map("posted_at") @db.Timestamptz(6)
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tickets           PosTicket[]
  payouts           PosPayout[]

  @@index([storeId, businessDate, status], map: "pos_shift_store_business_status_idx")
  @@index([registerId, status], map: "pos_shift_register_status_idx")
  @@map("pos_shift")
  @@schema("app")
}

/// Ticket header owned by the POS runtime. This is the active draft and the
/// completed receipt shell that downstream reporting reads from.
model PosTicket {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId               String            @map("shift_id") @db.Uuid
  shift                 PosShift          @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId               Int               @map("store_id") @db.SmallInt
  registerId            String            @map("register_id") @db.Uuid
  ticketNumber          Int               @map("ticket_number")
  status                String            @default("DRAFT") @db.VarChar(20)
  transactionType       String            @default("REGULAR") @map("transaction_type") @db.VarChar(32)
  cashierUserId         String            @map("cashier_user_id") @db.Uuid
  cashierName           String            @map("cashier_name") @db.VarChar(120)
  customerId            String?           @map("customer_id") @db.Uuid
  customerAccountNumber String?           @map("customer_account_number") @db.VarChar(80)
  customerName          String?           @map("customer_name") @db.VarChar(160)
  headerDiscountPct     Decimal?          @map("header_discount_pct") @db.Decimal(5, 2)
  promotionCode         String?           @map("promotion_code") @db.VarChar(40)
  shipToState           String?           @map("ship_to_state") @db.VarChar(40)
  subtotal              Decimal           @default(0) @db.Decimal(12, 2)
  taxTotal              Decimal           @default(0) @map("tax_total") @db.Decimal(12, 2)
  secondaryTaxTotal     Decimal           @default(0) @map("secondary_tax_total") @db.Decimal(12, 2)
  otherCharges          Decimal           @default(0) @map("other_charges") @db.Decimal(12, 2)
  grandTotal            Decimal           @default(0) @map("grand_total") @db.Decimal(12, 2)
  totalTendered         Decimal           @default(0) @map("total_tendered") @db.Decimal(12, 2)
  changeGiven           Decimal           @default(0) @map("change_given") @db.Decimal(12, 2)
  comment               String?
  receiptPayloadJson    Json?             @map("receipt_payload_json")
  voidedAt              DateTime?         @map("voided_at") @db.Timestamptz(6)
  completedAt           DateTime?         @map("completed_at") @db.Timestamptz(6)
  reclaimedFromTicketId String?           @map("reclaimed_from_ticket_id") @db.Uuid
  receiptPrintCount     Int               @default(0) @map("receipt_print_count")
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lines                 PosTicketLine[]
  tenders               PosTicketTender[]
  events                PosTicketEvent[]

  @@unique([shiftId, ticketNumber], map: "pos_ticket_shift_ticket_number_key")
  @@index([shiftId, status], map: "pos_ticket_shift_status_idx")
  @@index([storeId, completedAt], map: "pos_ticket_store_completed_idx")
  @@map("pos_ticket")
  @@schema("app")
}

/// Ticket detail lines. One row per SKU / size cell on the active ticket.
model PosTicketLine {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId          String    @map("ticket_id") @db.Uuid
  ticket            PosTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  lineNumber        Int       @map("line_number")
  skuId             String?   @map("sku_id") @db.Uuid
  skuCode           String?   @map("sku_code") @db.VarChar(15)
  description       String    @db.VarChar(160)
  upc               String?   @db.VarChar(16)
  sizeTypeCode      Int?      @map("size_type_code") @db.SmallInt
  columnLabel       String    @default("") @map("column_label") @db.VarChar(40)
  rowLabel          String    @default("") @map("row_label") @db.VarChar(40)
  quantity          Int
  unitPrice         Decimal   @map("unit_price") @db.Decimal(12, 2)
  priceMode         String    @default("RETAIL") @map("price_mode") @db.VarChar(24)
  discountPct       Decimal?  @map("discount_pct") @db.Decimal(5, 2)
  discountAmount    Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxable           Boolean   @default(true)
  taxRate           Decimal   @default(0.15) @map("tax_rate") @db.Decimal(5, 4)
  secondaryTaxRate  Decimal   @default(0) @map("secondary_tax_rate") @db.Decimal(5, 4)
  salespersonUserId String?   @map("salesperson_user_id") @db.Uuid
  salespersonCode   String?   @map("salesperson_code") @db.VarChar(16)
  salespersonName   String?   @map("salesperson_name") @db.VarChar(120)
  familyMemberId    String?   @map("family_member_id") @db.Uuid
  returnCode        Int?      @map("return_code") @db.SmallInt
  comment           String?
  lineSubtotal      Decimal   @default(0) @map("line_subtotal") @db.Decimal(12, 2)
  lineTax           Decimal   @default(0) @map("line_tax") @db.Decimal(12, 2)
  lineSecondaryTax  Decimal   @default(0) @map("line_secondary_tax") @db.Decimal(12, 2)
  lineTotal         Decimal   @default(0) @map("line_total") @db.Decimal(12, 2)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([ticketId, lineNumber], map: "pos_ticket_line_ticket_line_number_key")
  @@index([ticketId], map: "pos_ticket_line_ticket_idx")
  @@index([skuId], map: "pos_ticket_line_sku_idx")
  @@map("pos_ticket_line")
  @@schema("app")
}

/// Up to four tenders per ticket plus the semantic continuation row.
model PosTicketTender {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId      String        @map("ticket_id") @db.Uuid
  ticket        PosTicket     @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sequence      Int
  tenderTypeId  String        @map("tender_type_id") @db.Uuid
  tenderType    PosTenderType @relation(fields: [tenderTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tenderCode    String        @map("tender_code") @db.VarChar(10)
  tenderLabel   String        @map("tender_label") @db.VarChar(80)
  tenderKind    String        @map("tender_kind") @db.VarChar(32)
  amount        Decimal       @db.Decimal(12, 2)
  accountNumber String?       @map("account_number") @db.VarChar(80)
  reference     String?       @db.VarChar(120)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([ticketId, sequence], map: "pos_ticket_tender_ticket_sequence_key")
  @@index([ticketId], map: "pos_ticket_tender_ticket_idx")
  @@index([tenderTypeId], map: "pos_ticket_tender_type_idx")
  @@map("pos_ticket_tender")
  @@schema("app")
}

/// Audit trail for lifecycle transitions such as complete, void, reclaim, and
/// receipt reprint.
model PosTicketEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId    String    @map("ticket_id") @db.Uuid
  ticket      PosTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  shiftId     String    @map("shift_id") @db.Uuid
  eventType   String    @map("event_type") @db.VarChar(40)
  actorUserId String    @map("actor_user_id") @db.Uuid
  actorName   String?   @map("actor_name") @db.VarChar(120)
  payloadJson Json?     @map("payload_json")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([ticketId, createdAt], map: "pos_ticket_event_ticket_created_idx")
  @@index([shiftId, createdAt], map: "pos_ticket_event_shift_created_idx")
  @@map("pos_ticket_event")
  @@schema("app")
}

/// Cash removed from the drawer during an open shift.
model PosPayout {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId       String            @map("shift_id") @db.Uuid
  shift         PosShift          @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId       Int               @map("store_id") @db.SmallInt
  registerId    String            @map("register_id") @db.Uuid
  categoryId    String            @map("category_id") @db.Uuid
  category      PosPayoutCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  categoryCode  String            @map("category_code") @db.VarChar(20)
  categoryLabel String            @map("category_label") @db.VarChar(80)
  cashierUserId String            @map("cashier_user_id") @db.Uuid
  cashierName   String            @map("cashier_name") @db.VarChar(120)
  amount        Decimal           @db.Decimal(12, 2)
  note          String?
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([shiftId, createdAt], map: "pos_payout_shift_created_idx")
  @@index([storeId, createdAt], map: "pos_payout_store_created_idx")
  @@map("pos_payout")
  @@schema("app")
}
