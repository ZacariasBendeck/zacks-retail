  roleCode         String             @map("role_code")
  sizeLabel        String             @map("size_label")
  columnLabel      String             @default("") @map("column_label")
  rowLabel         String             @default("") @map("row_label")
  onHand           Int                @default(0) @map("on_hand")
  onOrder          Int                @default(0) @map("on_order")
  projectedSales   Int                @default(0) @map("projected_sales")
  targetEnding     Int                @default(0) @map("target_ending")
  recommendedQty   Int                @map("recommended_qty")
  unitCost         Decimal            @default(0) @map("unit_cost") @db.Decimal(12, 2)
  retailPrice      Decimal            @default(0) @map("retail_price") @db.Decimal(12, 2)
  categoryNumber   Int?               @map("category_number")
  departmentNumber Int?               @map("department_number") @db.SmallInt
  poLineId         String?            @map("po_line_id") @db.Uuid
  poLine           PurchaseOrderLine? @relation(fields: [poLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([planId], map: "matching_set_buy_plan_line_plan_idx")
  @@index([skuId], map: "matching_set_buy_plan_line_sku_idx")
  @@index([poLineId], map: "matching_set_buy_plan_line_po_line_idx")
  @@index([categoryNumber, departmentNumber], map: "matching_set_buy_plan_line_taxonomy_idx")
  @@map("matching_set_buy_plan_line")
  @@schema("app")
}

model SkuActivity {
