  commercialUnitCostHnl  Decimal?            @map("commercial_unit_cost_hnl") @db.Decimal(14, 4)
  allocatedLandedCostHnl Decimal?            @map("allocated_landed_cost_hnl") @db.Decimal(14, 2)
  landedUnitCostHnl      Decimal?            @map("landed_unit_cost_hnl") @db.Decimal(14, 4)
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([receiptId], map: "po_receipt_line_receipt_id_idx")
  @@index([poLineId], map: "po_receipt_line_po_line_id_idx")
  @@index([skuId], map: "po_receipt_line_sku_id_idx")
  @@index([importShipmentId, importInvoiceLineId], map: "po_receipt_line_import_ref_idx")
  @@map("po_receipt_line")
  @@schema("app")
}

model PoStatusHistory {
