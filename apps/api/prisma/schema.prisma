  @@schema("app")
}

/// Per-SKU size-label rows. Each SKU carries an ordered list of the sizes it
/// is sold in (e.g. "7", "7.5", "8", ...). `sort_order` controls display on
/// the size grid; `active` hides a size from new assignments without dropping
/// inventory rows that reference it. Matches the pre-migration SQLite shape
/// 1:1 with native Postgres types.
model SkuSize {
  id        String              @id @default(uuid()) @db.Uuid
  skuId     String              @map("sku_id") @db.Uuid
  sku       Sku                 @relation(fields: [skuId], references: [id], onDelete: Cascade)
  sizeLabel String              @map("size_label")
  sortOrder Int                 @default(0) @map("sort_order")
  active    Boolean             @default(true)
  inventory Inventory[]
  auditLog  InventoryAuditLog[]

  @@unique([skuId, sizeLabel])
  @@index([skuId], map: "sku_size_sku_id_idx")
  @@map("sku_size")
  @@schema("app")
}

/// Per-(SKU × size) on-hand + reserved state. One row per size when the SKU
/// has a size grid; `sku_size_id = null` for SKUs that don't (accessories,
/// single-variant items). `(sku_id, sku_size_id)` is unique so the pair is
/// the natural join key for mutations from adjustmentService / ticketService.
model Inventory {
  id               String    @id @default(uuid()) @db.Uuid
  skuId            String    @map("sku_id") @db.Uuid
  sku              Sku       @relation(fields: [skuId], references: [id])
  skuSizeId        String?   @map("sku_size_id") @db.Uuid
  skuSize          SkuSize?  @relation(fields: [skuSizeId], references: [id])
  quantityOnHand   Int       @default(0) @map("quantity_on_hand")
  quantityReserved Int       @default(0) @map("quantity_reserved")
  lastCountedAt    DateTime? @map("last_counted_at")
  version          Int       @default(1)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([skuId, skuSizeId], map: "inventory_sku_size_unique")
  @@index([skuId], map: "inventory_sku_id_idx")
  @@map("inventory")
  @@schema("app")
}

/// Append-only trail of every quantity adjustment. Referenced by
/// adjustmentService, inventoryService, and admin reports ("who moved
/// stock when and why"). `resultingBalance` is the on-hand quantity
/// AFTER the adjustment applied — lets the audit UI render a ledger
/// without re-running the math.
model InventoryAuditLog {
  id                    String   @id @default(uuid()) @db.Uuid
  skuId                 String   @map("sku_id") @db.Uuid
  sku                   Sku      @relation(fields: [skuId], references: [id])
  skuSizeId             String?  @map("sku_size_id") @db.Uuid
  skuSize               SkuSize? @relation(fields: [skuSizeId], references: [id])
  adjustment            Int
  reason                String
  resultingBalance      Int      @map("resulting_balance")
  performedBy           String   @default("system") @map("performed_by")
  sourceDocumentRefType String?  @map("source_document_ref_type")
  sourceDocumentRefId   String?  @map("source_document_ref_id")
  idempotencyKey        String?  @unique(map: "inventory_audit_log_idempotency_key") @map("idempotency_key")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([skuId], map: "inventory_audit_log_sku_id_idx")
  @@index([createdAt], map: "inventory_audit_log_created_at_idx")
  @@index([sourceDocumentRefType, sourceDocumentRefId], map: "inventory_audit_log_source_ref_idx")
  @@map("inventory_audit_log")
  @@schema("app")
}

model InventoryAdjustment {
  id             String                    @id @default(uuid()) @db.Uuid
  type           String
  fromLocationId String?                   @map("from_location_id")
  toLocationId   String?                   @map("to_location_id")
  reason         String?
  createdBy      String                    @map("created_by")
  createdAt      DateTime                  @default(now()) @map("created_at")
  lines          InventoryAdjustmentLine[]

  @@index([type, createdAt(sort: Desc)], map: "inventory_adjustment_type_created_idx")
  @@index([createdAt(sort: Desc)], map: "inventory_adjustment_created_at_idx")
  @@map("inventory_adjustment")
  @@schema("app")
}

model InventoryAdjustmentLine {
  id           String              @id @default(uuid()) @db.Uuid
  adjustmentId String              @map("adjustment_id") @db.Uuid
  adjustment   InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  skuId        String              @map("sku_id") @db.Uuid
  sku          Sku                 @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  quantity     Int
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([adjustmentId, createdAt], map: "inventory_adjustment_line_adjustment_created_idx")
  @@index([skuId], map: "inventory_adjustment_line_sku_id_idx")
  @@map("inventory_adjustment_line")
  @@schema("app")
}

/// Store-aware stock projection keyed per (store × SKU × size-grid cell).
/// This is the additive surface for inventory-module writes that must not live
/// in SQLite.
model StockLevel {
  id             String    @id @default(uuid()) @db.Uuid
  storeId        Int       @map("store_id")
  skuId          String    @map("sku_id") @db.Uuid
  sku            Sku       @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  columnLabel    String    @default("") @map("column_label")
  rowLabel       String    @default("") @map("row_label")
  onHand         Int       @default(0) @map("on_hand")
  reserved       Int       @default(0)
  lastReceivedAt DateTime? @map("last_received_at")
  lastMovementAt DateTime? @map("last_movement_at")
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([storeId, skuId, columnLabel, rowLabel], map: "stock_level_store_sku_cell_key")
  @@index([skuId, storeId], map: "stock_level_sku_store_idx")
  @@index([storeId, onHand], map: "stock_level_store_on_hand_idx")
  @@map("stock_level")
  @@schema("app")
}

/// Append-only movement ledger for store-aware inventory operations.
model StockMovement {
  id                   String             @id @default(uuid()) @db.Uuid
  storeId              Int                @map("store_id")
  skuId                String             @map("sku_id") @db.Uuid
  sku                  Sku                @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  columnLabel          String             @default("") @map("column_label")
  rowLabel             String             @default("") @map("row_label")
  movementType         String             @map("movement_type")
  quantityDelta        Int                @map("quantity_delta")
  unitCostSnapshot     Decimal?           @map("unit_cost_snapshot") @db.Decimal(12, 2)
  retailPriceSnapshot  Decimal?           @map("retail_price_snapshot") @db.Decimal(12, 2)
  sourceDocumentType   String             @map("source_document_type")
  sourceDocumentId     String             @map("source_document_id")
  reasonCode           String?            @map("reason_code")
  comment              String?
  performedBy          String             @map("performed_by")
  movementAt           DateTime           @map("movement_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  idempotencyKey       String?            @unique(map: "stock_movement_idempotency_key") @map("idempotency_key")
  manualReceiptLine    ManualReceiptLine? @relation("ManualReceiptLineMovement")
  manualReturnLine     ManualReturnLine?  @relation("ManualReturnLineMovement")
  transferLineOutbound TransferLine[]     @relation("TransferLineOutboundMovement")
  transferLineInbound  TransferLine[]     @relation("TransferLineInboundMovement")
  stockCostEvents      StockCostEvent[]

  @@index([skuId, storeId, movementAt(sort: Desc)], map: "stock_movement_sku_store_movement_at_idx")
  @@index([movementType, movementAt(sort: Desc)], map: "stock_movement_type_movement_at_idx")
  @@index([storeId, movementAt(sort: Desc)], map: "stock_movement_store_movement_at_idx")
  @@index([sourceDocumentType, sourceDocumentId], map: "stock_movement_source_document_idx")
  @@map("stock_movement")
  @@schema("app")
}

model StockCostEvent {
  id                 String         @id @default(uuid()) @db.Uuid
  stockMovementId    String?        @map("stock_movement_id") @db.Uuid
  stockMovement      StockMovement? @relation(fields: [stockMovementId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  storeId            Int            @map("store_id")
  skuId              String         @map("sku_id") @db.Uuid
  sku                Sku            @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  quantityDelta      Decimal        @map("quantity_delta") @db.Decimal(12, 3)
  valueDeltaHnl      Decimal        @map("value_delta_hnl") @db.Decimal(14, 2)
  unitCostHnl        Decimal?       @map("unit_cost_hnl") @db.Decimal(14, 4)
  valuationBasis     String         @map("valuation_basis") @db.VarChar(24)
  sourceDocumentType String         @map("source_document_type") @db.VarChar(64)
  sourceDocumentId   String         @map("source_document_id")
  postedBy           String         @map("posted_by")
  postedAt           DateTime       @default(now()) @map("posted_at") @db.Timestamptz(6)
  idempotencyKey     String?        @unique(map: "stock_cost_event_idempotency_key") @map("idempotency_key")

  @@index([skuId, storeId, postedAt(sort: Desc)], map: "stock_cost_event_sku_store_idx")
  @@map("stock_cost_event")
  @@schema("app")
}

model StockCostBalance {
  storeId            Int      @map("store_id")
  skuId              String   @map("sku_id") @db.Uuid
  sku                Sku      @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  quantityOnHand     Decimal  @default(0) @map("quantity_on_hand") @db.Decimal(12, 3)
  inventoryValueHnl  Decimal  @default(0) @map("inventory_value_hnl") @db.Decimal(14, 2)
  averageUnitCostHnl Decimal? @map("average_unit_cost_hnl") @db.Decimal(14, 4)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@id([storeId, skuId])
  @@index([skuId], map: "stock_cost_balance_sku_idx")
  @@map("stock_cost_balance")
  @@schema("app")
}

/// One saved "Enter Manual Receipts" document in the inventory module.
/// One document represents one SKU receipt into one store, with one or more
/// size-grid cell lines.
model ManualReceipt {
  id                   String              @id @default(uuid()) @db.Uuid
  storeId              Int                 @map("store_id")
  skuId                String              @map("sku_id") @db.Uuid
  sku                  Sku                 @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  performedBy          String              @map("performed_by")
  referenceNumber      String?             @map("reference_number")
  storeLabelsOnReceive Boolean             @default(false) @map("store_labels_on_receive")
  movementAt           DateTime            @map("movement_at")
  unitCostOverride     Decimal?            @map("unit_cost_override") @db.Decimal(12, 2)
  retailPriceOverride  Decimal?            @map("retail_price_override") @db.Decimal(12, 2)
  casePackId           String?             @map("case_pack_id")
  casePackMultiplier   Int?                @map("case_pack_multiplier")
  note                 String?
  idempotencyKey       String?             @unique(map: "manual_receipt_idempotency_key") @map("idempotency_key")
  createdAt            DateTime            @default(now()) @map("created_at")
  lines                ManualReceiptLine[]

  @@index([storeId, movementAt(sort: Desc)], map: "manual_receipt_store_movement_at_idx")
  @@index([skuId, movementAt(sort: Desc)], map: "manual_receipt_sku_movement_at_idx")
  @@map("manual_receipt")
  @@schema("app")
}

model ManualReceiptLine {
  id              String        @id @default(uuid()) @db.Uuid
  manualReceiptId String        @map("manual_receipt_id") @db.Uuid
  manualReceipt   ManualReceipt @relation(fields: [manualReceiptId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  columnLabel     String        @default("") @map("column_label")
  rowLabel        String        @default("") @map("row_label")
  quantity        Int
  unitCost        Decimal       @map("unit_cost") @db.Decimal(12, 2)
  retailPrice     Decimal       @map("retail_price") @db.Decimal(12, 2)
  movementId      String        @unique(map: "manual_receipt_line_movement_id_key") @map("movement_id") @db.Uuid
  movement        StockMovement @relation("ManualReceiptLineMovement", fields: [movementId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([manualReceiptId, columnLabel, rowLabel], map: "manual_receipt_line_cell_key")
  @@index([manualReceiptId], map: "manual_receipt_line_receipt_id_idx")
  @@map("manual_receipt_line")
  @@schema("app")
}

/// Import Management shipment/voyage header. This is not CSV/RICS importing;
/// it is the international buying, goods-in-transit, and landed-cost workflow.
model ImportShipment {
  id                  String    @id @default(uuid()) @db.Uuid
  shipmentNumber      String    @unique(map: "import_shipment_number_key") @map("shipment_number") @db.VarChar(64)
  displayName         String    @map("display_name")
  status              String    @default("DRAFT") @db.VarChar(32)
  buyer               String?
  originPort          String?   @map("origin_port")
  destinationPort     String?   @map("destination_port")
  carrier             String?
  freightForwarder    String?   @map("freight_forwarder")
  customsPolicyNumber String?   @map("customs_policy_number")
  blNumber            String?   @map("bl_number")
  expectedDepartureAt DateTime? @map("expected_departure_at") @db.Date
  expectedArrivalAt   DateTime? @map("expected_arrival_at") @db.Date
  actualArrivalAt     DateTime? @map("actual_arrival_at") @db.Date
  baseCurrency        String    @default("HNL") @map("base_currency") @db.VarChar(3)
  sourceWorkbookName  String?   @map("source_workbook_name")
  notes               String?
  approvedEstimateAt  DateTime? @map("approved_estimate_at") @db.Timestamptz(6)
  approvedEstimateBy  String?   @map("approved_estimate_by")
  finalLiquidationAt  DateTime? @map("final_liquidation_at") @db.Timestamptz(6)
  closedAt            DateTime? @map("closed_at") @db.Timestamptz(6)
  createdBy           String    @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  containers           ImportContainer[]
  shipmentLines        ImportShipmentLine[]
  supplierInvoices     ImportSupplierInvoice[]
  charges              ImportCharge[]
  allocations          ImportLandedCostAllocation[]
  goodsInTransit       GoodsInTransitRecord[]
  verificationChecks   ImportVerificationCheck[]
  suggestedPrices      ImportSuggestedPrice[]
  payableHandoffs      ImportPayableHandoff[]
  inventoryReceipts    ImportInventoryReceipt[]
  inventoryTrueUps     ImportInventoryTrueUp[]
  costBuilds           ImportCostBuild[]
  componentAllocations ImportCostComponentAllocation[]
  poReceiptLines       PoReceiptLine[]

  @@index([status, expectedArrivalAt], map: "import_shipment_status_arrival_idx")
  @@index([buyer, status], map: "import_shipment_buyer_status_idx")
  @@map("import_shipment")
  @@schema("app")
}

model ImportContainer {
  id                String         @id @default(uuid()) @db.Uuid
  shipmentId        String         @map("shipment_id") @db.Uuid
  shipment          ImportShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  containerNumber   String?        @map("container_number")
  containerType     String         @default("CONTAINER") @map("container_type") @db.VarChar(24)
  sealNumber        String?        @map("seal_number")
  cargoGroup        String?        @map("cargo_group")
  status            String         @default("PLANNED") @db.VarChar(24)
  expectedArrivalAt DateTime?      @map("expected_arrival_at") @db.Date
  actualArrivalAt   DateTime?      @map("actual_arrival_at") @db.Date
  notes             String?
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  goodsInTransit GoodsInTransitRecord[]
  shipmentLines  ImportShipmentLine[]

  @@index([shipmentId], map: "import_container_shipment_id_idx")
  @@map("import_container")
  @@schema("app")
}

model ImportShipmentLine {
  id                         String             @id @default(uuid()) @db.Uuid
  shipmentId                 String             @map("shipment_id") @db.Uuid
  shipment                   ImportShipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  purchaseOrderLineId        String             @map("purchase_order_line_id") @db.Uuid
  purchaseOrderLine          PurchaseOrderLine  @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  containerId                String?            @map("container_id") @db.Uuid
  container                  ImportContainer?   @relation(fields: [containerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  invoiceLineId              String?            @map("invoice_line_id") @db.Uuid
  invoiceLine                ImportInvoiceLine? @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  expectedQuantity           Decimal            @map("expected_quantity") @db.Decimal(12, 3)
  sourceUnitCost             Decimal?           @map("source_unit_cost") @db.Decimal(14, 4)
  sourceCurrency             String             @map("source_currency") @db.VarChar(3)
  fxRate                     Decimal            @map("fx_rate") @db.Decimal(18, 8)
  fxDate                     DateTime           @map("fx_date") @db.Date
  incotermCode               String?            @map("incoterm_code") @db.VarChar(8)
  incotermPlace              String?            @map("incoterm_place")
  commercialUnitCostHnl      Decimal            @map("commercial_unit_cost_hnl") @db.Decimal(14, 4)
  estimatedLandedUnitCostHnl Decimal            @map("estimated_landed_unit_cost_hnl") @db.Decimal(14, 4)
  allocatedLandedCostHnl     Decimal            @default(0) @map("allocated_landed_cost_hnl") @db.Decimal(14, 2)
  landedUnitCostHnl          Decimal?           @map("landed_unit_cost_hnl") @db.Decimal(14, 4)
  status                     String             @default("EXPECTED") @db.VarChar(24)
  invoiceMatchApprovedAt     DateTime?          @map("invoice_match_approved_at") @db.Timestamptz(6)
  invoiceMatchApprovedBy     String?            @map("invoice_match_approved_by")
  invoiceMatchApprovalReason String?            @map("invoice_match_approval_reason")
  notes                      String?
  createdAt                  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  allocations                ImportLandedCostAllocation[]
  goodsInTransit             GoodsInTransitRecord[]
  costBuildOutputs           ImportCostBuild[]               @relation("ImportCostBuildOutputShipmentLine")
  outputComponentAllocations ImportCostComponentAllocation[] @relation("ImportOutputShipmentLine")
  poReceiptLines             PoReceiptLine[]

  @@unique([shipmentId, purchaseOrderLineId], map: "import_shipment_line_unique_po_line_key")
  @@index([shipmentId], map: "import_shipment_line_shipment_id_idx")
  @@index([purchaseOrderLineId], map: "import_shipment_line_po_line_id_idx")
  @@index([invoiceLineId], map: "import_shipment_line_invoice_line_id_idx")
  @@index([containerId], map: "import_shipment_line_container_id_idx")
  @@map("import_shipment_line")
  @@schema("app")
}

model ImportSupplierInvoice {
  id             String         @id @default(uuid()) @db.Uuid
  shipmentId     String         @map("shipment_id") @db.Uuid
  shipment       ImportShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  invoiceNumber  String         @map("invoice_number")
  supplierCode   String?        @map("supplier_code") @db.VarChar(16)
  supplierName   String         @map("supplier_name")
  invoiceDate    DateTime?      @map("invoice_date") @db.Date
  invoiceGroup   String         @default("TAXABLE") @map("invoice_group") @db.VarChar(24)
  invoiceKind    String         @default("MERCHANDISE") @map("invoice_kind") @db.VarChar(24)
  sourceAmount   Decimal        @map("source_amount") @db.Decimal(14, 4)
  sourceCurrency String         @map("source_currency") @db.VarChar(3)
  fxRate         Decimal        @map("fx_rate") @db.Decimal(18, 8)
  fxDate         DateTime       @map("fx_date") @db.Date
  hnlAmount      Decimal        @map("hnl_amount") @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  lines ImportInvoiceLine[]

  @@index([shipmentId], map: "import_supplier_invoice_shipment_id_idx")
  @@index([supplierCode], map: "import_supplier_invoice_supplier_code_idx")
  @@map("import_supplier_invoice")
  @@schema("app")
}

model ImportInvoiceLine {
  id                        String                @id @default(uuid()) @db.Uuid
  invoiceId                 String                @map("invoice_id") @db.Uuid
  invoice                   ImportSupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  skuId                     String?               @map("sku_id") @db.Uuid
  purchaseOrderLineId       String?               @map("purchase_order_line_id") @db.Uuid
  lineNumber                Int                   @map("line_number")
  itemCode                  String?               @map("item_code")
  styleCode                 String?               @map("style_code")
  description               String?
  materialMeters            Decimal?              @map("material_meters") @db.Decimal(12, 3)
  cartonCount               Decimal?              @map("carton_count") @db.Decimal(12, 3)
  weightKg                  Decimal?              @map("weight_kg") @db.Decimal(12, 3)
  volumeCbm                 Decimal?              @map("volume_cbm") @db.Decimal(12, 3)
  quantity                  Decimal               @db.Decimal(12, 3)
  unitOfMeasure             String                @default("UNIT") @map("unit_of_measure") @db.VarChar(16)
  sourceUnitCost            Decimal?              @map("source_unit_cost") @db.Decimal(14, 4)
  sourceAmount              Decimal               @map("source_amount") @db.Decimal(14, 4)
  sourceCurrency            String                @map("source_currency") @db.VarChar(3)
  fxRate                    Decimal               @map("fx_rate") @db.Decimal(18, 8)
  fxDate                    DateTime              @map("fx_date") @db.Date
  hnlAmount                 Decimal               @map("hnl_amount") @db.Decimal(14, 2)
  baseUnitCostHnl           Decimal               @map("base_unit_cost_hnl") @db.Decimal(14, 4)
  allocatedLandedCostHnl    Decimal               @default(0) @map("allocated_landed_cost_hnl") @db.Decimal(14, 2)
  landedUnitCostHnl         Decimal?              @map("landed_unit_cost_hnl") @db.Decimal(14, 4)
  costRole                  String                @default("FINISHED_GOOD") @map("cost_role") @db.VarChar(32)
  receiptPolicy             String                @default("RECEIVE_TO_STOCK") @map("receipt_policy") @db.VarChar(32)
  allocationGroupKey        String?               @map("allocation_group_key")
  componentAllocatedCostHnl Decimal               @default(0) @map("component_allocated_cost_hnl") @db.Decimal(14, 2)
  commercialUnitCostHnl     Decimal?              @map("commercial_unit_cost_hnl") @db.Decimal(14, 4)
  taxable                   Boolean               @default(true)
  createdAt                 DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  allocations                ImportLandedCostAllocation[]
  goodsInTransit             GoodsInTransitRecord[]
  importShipmentLines        ImportShipmentLine[]
  suggestedPrices            ImportSuggestedPrice[]
  inventoryReceipts          ImportInventoryReceipt[]
  inventoryTrueUps           ImportInventoryTrueUp[]
  costBuildOutputs           ImportCostBuild[]               @relation("ImportCostBuildOutputInvoiceLine")
  componentAllocations       ImportCostComponentAllocation[] @relation("ImportComponentInvoiceLine")
  outputComponentAllocations ImportCostComponentAllocation[] @relation("ImportOutputInvoiceLine")
  poReceiptLines             PoReceiptLine[]

  @@unique([invoiceId, lineNumber], map: "import_invoice_line_number_key")
  @@index([invoiceId], map: "import_invoice_line_invoice_id_idx")
