// Zack's Retail — API Prisma schema.
//
// Scope: Postgres-backed application tables for storefront, admin,
// product/catalog, reporting, and operational workflows.
//
// PostgreSQL is the system of record for all net-new application data.
// SQLite remains only as a frozen read-store for legacy admin reference tables
// such as ref_colors, ref_patterns, and related dimensions while they are
// migrated piecewise into app.* Postgres dimensions.
//
// Legacy RICS v7.7 Access MDB files are read only through offline extract
// tooling that produces CSV artifact packs for direct Postgres imports:
//
//   RICS MDB → PowerShell/C# ACE.OLEDB export → CSV artifact pack → app/module imports
//
// The API must not read directly from or write to RICS MDB files.
// The API must not create new SQLite writes.
//
// RICS SKU codes are treated as opaque external string keys.
// Module specs in docs/modules/*.md are governed contracts and should stay
// aligned with this schema.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

generator apiClient {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../generated/prisma-client-v7"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "platform", "app"]
}

/// Web-only overlay keyed by RICS SKU code.
/// Fields here override or extend what RICS carries (description, imagery, SEO).
/// A product with no row here still renders — it just uses RICS fields only.
model ProductContent {
  ricsSkuCode    String   @id
  webDescription String?
  heroImageUrl   String?
  galleryJson    Json?
  specsJson      Json?
  seoSlug        String?  @unique
  published      Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@schema("public")
}

/// Anonymous cart keyed by a session cookie (UUID). User accounts come later.
model Cart {
  id        String     @id @default(uuid())
  sessionId String     @unique
  lines     CartLine[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@schema("public")
}

model CartLine {
  id                String   @id @default(uuid())
  cartId            String
  cart              Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  ricsSkuCode       String
  sizeLabel         String
  colorId           Int?
  quantity          Int
  unitPriceSnapshot Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())

  @@index([cartId])
  @@index([ricsSkuCode])
  @@schema("public")
}

model Order {
  id            String      @id @default(uuid())
  status        String      @default("PLACED")
  shippingJson  Json
  paymentMethod String
  subtotal      Decimal     @db.Decimal(12, 2)
  tax           Decimal     @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  lines         OrderLine[]
  createdAt     DateTime    @default(now())

  @@schema("public")
}

model OrderLine {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ricsSkuCode String
  sizeLabel   String
  colorId     Int?
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@schema("public")
}

model User {
  id                         String                       @id @default(uuid())
  email                      String                       @unique
  passwordHash               String
  displayName                String
  preferredLocale            String?                      @map("preferred_locale")
  active                     Boolean                      @default(true)
  isEmployee                 Boolean                      @default(false)
  ricsUserId                 String?
  salespersonCode            String?
  otherInformation           String?
  commissionRate             Decimal?                     @db.Decimal(5, 2)
  commissionBase             String                       @default("NET_SALES")
  homeStoreId                String?
  hireDate                   DateTime?
  terminatedAt               DateTime?
  timeClockEnabled           Boolean                      @default(true)
  timeClockPinHash           String?
  roleId                     String
  role                       Role                         @relation(fields: [roleId], references: [id])
  sessions                   Session[]
  identityRoleAssignments    IdentityUserRoleAssignment[]
  identityStoreScopes        IdentityUserStoreScope[]
  identityMfaFactors         IdentityMfaFactor[]
  identityExternalIdentities IdentityExternalIdentity[]
  salesPasswords             EmployeeSalesPassword[]      @relation("EmployeeSalesPasswords")
  salesPasswordAudits        EmployeeSalesPasswordAudit[] @relation("EmployeeSalesPasswordAuditEmployee")
  salesOverrideTokens        EmployeeSalesOverrideToken[] @relation("EmployeeSalesOverrideTokens")
  commissionOverrides        CommissionOverride[]
  timeClockEntries           TimeClockEntry[]             @relation("EmployeeTimeClockEntries")
  ownedReportTemplates       ReportTemplate[]             @relation("OwnedReportTemplates")
  reportRuns                 ReportRun[]                  @relation("ReportRuns")
  lastLoginAt                DateTime?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt

  @@index([roleId])
  @@index([isEmployee, active])
  @@index([salespersonCode])
  @@schema("public")
}

/// App-owned employee / salesperson master. RICS Salespeople records are
/// imported here rather than into auth users; active login accounts may still
/// reference the same salesperson code from public.User.
model Employee {
  id                        String    @id @default(uuid()) @db.Uuid
  salespersonCode           String    @unique @map("salesperson_code") @db.VarChar(16)
  displayName               String    @map("display_name")
  active                    Boolean   @default(false)
  otherInformation          String?   @map("other_information")
  commissionRate            Decimal?  @map("commission_rate") @db.Decimal(5, 2)
  commissionBase            String    @default("NET_SALES") @map("commission_base")
  ricsCommissionMethod      String?   @map("rics_commission_method") @db.VarChar(8)
  timeClockEnabled          Boolean   @default(true) @map("time_clock_enabled")
  timeClockPinHash          String?   @map("time_clock_pin_hash")
  timeClockAdmin            Boolean   @default(false) @map("time_clock_admin")
  timeClockFullUser         Boolean   @default(false) @map("time_clock_full_user")
  legacyCashierPinHash      String?   @map("legacy_cashier_pin_hash")
  ricsSalespersonChangedAt  DateTime? @map("rics_salesperson_changed_at") @db.Timestamp(3)
  ricsSalespersonImportedAt DateTime? @map("rics_salesperson_imported_at") @db.Timestamp(3)
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([active], map: "employee_active_idx")
  @@map("employee")
  @@schema("app")
}

model Role {
  id                      String                       @id @default(uuid())
  name                    String                       @unique
  permissions             String[]
  description             String?
  archivedAt              DateTime?                    @map("archived_at")
  users                   User[]
  identityRoleAssignments IdentityUserRoleAssignment[]
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  @@index([archivedAt], map: "role_archived_at_idx")
  @@schema("public")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@schema("public")
}

/// Identity & Access module -- durable role assignment history. The current
/// User.roleId column remains as the compatibility read path during migration.
model IdentityUserRoleAssignment {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId           String    @map("role_id")
  role             Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  assignedByUserId String?   @map("assigned_by_user_id")
  assignedAt       DateTime  @default(now()) @map("assigned_at")
  revokedByUserId  String?   @map("revoked_by_user_id")
  revokedAt        DateTime? @map("revoked_at")
  reason           String?
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([userId, revokedAt], map: "identity_user_role_assignment_user_active_idx")
  @@index([roleId, revokedAt], map: "identity_user_role_assignment_role_active_idx")
  @@map("identity_user_role_assignment")
  @@schema("public")
}

/// Identity & Access module -- store/data visibility grants. V1 supports
/// ALL_STORES, STORE, and WAREHOUSE; region/group scopes can be added later.
model IdentityUserStoreScope {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType       String    @map("scope_type")
  scopeId         String?   @map("scope_id")
  grantedByUserId String?   @map("granted_by_user_id")
  grantedAt       DateTime  @default(now()) @map("granted_at")
  revokedByUserId String?   @map("revoked_by_user_id")
  revokedAt       DateTime? @map("revoked_at")
  reason          String?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([userId, revokedAt], map: "identity_user_store_scope_user_active_idx")
  @@index([scopeType, scopeId], map: "identity_user_store_scope_scope_idx")
  @@map("identity_user_store_scope")
  @@schema("public")
}

/// Identity & Access module -- MFA enrollment records. Secrets/public keys are
/// intentionally stored as opaque values so TOTP and WebAuthn can coexist.
model IdentityMfaFactor {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  factorType    String    @map("factor_type")
  label         String?
  secretHash    String?   @map("secret_hash")
  publicKeyJson Json?     @map("public_key_json")
  active        Boolean   @default(true)
  verifiedAt    DateTime? @map("verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  revokedAt     DateTime? @map("revoked_at")

  @@index([userId, active], map: "identity_mfa_factor_user_active_idx")
  @@map("identity_mfa_factor")
  @@schema("public")
}

/// Identity & Access module -- future SSO/OAuth/SAML identity mapping.
model IdentityExternalIdentity {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider            String
  providerSubject     String    @map("provider_subject")
  emailAtProvider     String?   @map("email_at_provider")
  createdAt           DateTime  @default(now()) @map("created_at")
  lastAuthenticatedAt DateTime? @map("last_authenticated_at")

  @@unique([provider, providerSubject], map: "identity_external_identity_provider_subject_key")
  @@index([userId], map: "identity_external_identity_user_idx")
  @@map("identity_external_identity")
  @@schema("public")
}

/// Identity & Access module -- login trail for security reporting.
model IdentityLoginEvent {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  roleId     String?  @map("role_id")
  email      String
  outcome    String
  reason     String?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([userId, occurredAt(sort: Desc)], map: "identity_login_event_user_idx")
  @@index([email, occurredAt(sort: Desc)], map: "identity_login_event_email_idx")
  @@index([outcome, occurredAt(sort: Desc)], map: "identity_login_event_outcome_idx")
  @@map("identity_login_event")
  @@schema("public")
}

/// Identity & Access module -- session lifecycle trail for revoke/report flows.
model IdentitySessionEvent {
  id         String   @id @default(uuid())
  sessionId  String?  @map("session_id")
  userId     String?  @map("user_id")
  eventType  String   @map("event_type")
  reason     String?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([userId, occurredAt(sort: Desc)], map: "identity_session_event_user_idx")
  @@index([sessionId, occurredAt(sort: Desc)], map: "identity_session_event_session_idx")
  @@map("identity_session_event")
  @@schema("public")
}

model EmployeeSalesPassword {
  id                           String                       @id @default(uuid())
  employeeId                   String
  employee                     User                         @relation("EmployeeSalesPasswords", fields: [employeeId], references: [id], onDelete: Cascade)
  pinHash                      String
  scopes                       String[]
  active                       Boolean                      @default(true)
  failedAttempts               Int                          @default(0)
  failedAttemptWindowStartedAt DateTime?
  dailyFailedCount             Int                          @default(0)
  dailyFailedWindowStartedAt   DateTime?
  lockedUntil                  DateTime?
  revokedAt                    DateTime?
  issuedByUserId               String
  updatedByUserId              String?
  audits                       EmployeeSalesPasswordAudit[]
  overrideTokens               EmployeeSalesOverrideToken[]
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt

  @@index([employeeId, active])
  @@index([lockedUntil])
  @@schema("public")
}

model EmployeeSalesPasswordAudit {
  id             String                 @id @default(uuid())
  employeeId     String
  employee       User                   @relation("EmployeeSalesPasswordAuditEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  passwordId     String?
  password       EmployeeSalesPassword? @relation(fields: [passwordId], references: [id], onDelete: SetNull)
  scope          String
  outcome        String
  invokingUserId String?
  ticketId       String?
  action         String?
  ipAddress      String?
  createdAt      DateTime               @default(now())

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([scope, createdAt(sort: Desc)])
  @@schema("public")
}

model EmployeeSalesOverrideToken {
  id             String                @id @default(uuid())
  passwordId     String
  password       EmployeeSalesPassword @relation(fields: [passwordId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       User                  @relation("EmployeeSalesOverrideTokens", fields: [employeeId], references: [id], onDelete: Cascade)
  scope          String
  tokenHash      String                @unique
  ticketId       String?
  action         String?
  invokingUserId String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime              @default(now())

  @@index([employeeId, scope, expiresAt])
  @@index([consumedAt])
  @@schema("public")
}

model TimeClockPolicy {
  storeId                  Int      @id
  enabled                  Boolean  @default(false)
  requireClockInBeforeSale Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@schema("public")
}

model TimeClockEntry {
  id                 String                     @id @default(uuid())
  employeeId         String
  employee           User                       @relation("EmployeeTimeClockEntries", fields: [employeeId], references: [id], onDelete: Cascade)
  storeId            Int
  clockedInAt        DateTime
  clockedOutAt       DateTime?
  nonSales           Boolean                    @default(false)
  clockedInByUserId  String
  clockedOutByUserId String?
  autoClosedAtCap    Boolean                    @default(false)
  note               String?
  adjustments        TimeClockEntryAdjustment[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([employeeId, clockedOutAt])
  @@index([storeId, clockedOutAt])
  @@index([clockedInAt])
  @@schema("public")
}

model TimeClockEntryAdjustment {
  id                      String         @id @default(uuid())
  timeClockEntryId        String
  timeClockEntry          TimeClockEntry @relation(fields: [timeClockEntryId], references: [id], onDelete: Cascade)
  employeeId              String
  actedByUserId           String
  reason                  String
  previousStoreId         Int
  nextStoreId             Int
  previousClockedInAt     DateTime
  nextClockedInAt         DateTime
  previousClockedOutAt    DateTime?
  nextClockedOutAt        DateTime?
  previousNonSales        Boolean
  nextNonSales            Boolean
  previousAutoClosedAtCap Boolean
  nextAutoClosedAtCap     Boolean
  previousNote            String?
  nextNote                String?
  createdAt               DateTime       @default(now())

  @@index([timeClockEntryId, createdAt(sort: Desc)])
  @@index([employeeId, createdAt(sort: Desc)])
  @@schema("public")
}

enum CommissionOverrideScope {
  SKU
  CATEGORY
  DEPARTMENT

  @@schema("public")
}

model CommissionOverride {
  id              String                  @id @default(uuid())
  employeeId      String
  employee        User                    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  scope           CommissionOverrideScope
  skuId           String?
  categoryId      String?
  departmentId    String?
  rate            Decimal                 @db.Decimal(5, 2)
  effectiveFrom   DateTime                @default(now())
  effectiveTo     DateTime?
  createdByUserId String
  updatedByUserId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([employeeId, scope])
  @@index([effectiveFrom, effectiveTo])
  @@schema("public")
}

/// Phase 1 audit log for products-module mutations against the live RICS MDBs.
/// Every create/update/delete on a taxonomy entity (Department, Category,
/// Sector, Group, Keyword, PromotionCode, SizeType) or a future products write
/// path (SKU, Vendor, Price Change, UPC) writes one row here. The audit log is
/// observability — product correctness depends on the Access write succeeding,
/// not on this row being present. Writers should treat Postgres failures as
/// non-blocking and log them.
///
/// Retention is unbounded in Phase 1; Phase 2 will add a retention policy.
model ProductsAuditLog {
  id          String   @id @default(uuid())
  actor       String // user id, email, or "system" for scheduled-job writes
  action      String // e.g. "department.create", "sizeType.update"
  targetTable String // RICS table, e.g. "RIDEPT.Departments"
  targetPk    String // primary-key value as a string (numbers stringified)
  payloadJson Json // before/after snapshot for the mutation
  occurredAt  DateTime @default(now())

  @@index([occurredAt])
  @@index([targetTable, targetPk])
  @@schema("public")
}

/// Season descriptions — user-defined taxonomy tags assigned to SKUs.
///
/// Clarified 2026-04-19: Seasons are a simple user-editable attribute on
/// SKUs, just like Groups or Categories. The user picks any code + description
/// that fits their reporting workflow — no fixed code universe, no computed
/// "current season" based on dates (that concept was a misread of RICS
/// Company Setup → Season Ending Months, which is only a reporting-date
/// filter, NOT a constraint on the seasons themselves).
///
/// RICS stores these in RISEMF.MDB (p. 218, Season Setup). This customer's
/// copy of that file does not open with ACE.OLEDB.12.0, so we mirror the
/// descriptions in Postgres. SKU counts still come from
/// InventoryMaster.Season via the Access read path.
model SeasonOverlay {
  code            String   @id @db.VarChar(2)
  description     String   @db.VarChar(32)
  dateLastChanged DateTime @default(now()) @updatedAt

  @@schema("public")
}

/// One row per RICS reload. Written by the `pnpm sync:rics` CLI.
model EtlRun {
  id         String        @id @default(uuid())
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  status     String // "running" | "ok" | "failed"
  totalRows  BigInt        @default(0)
  tableCount Int           @default(0)
  errorText  String?
  tables     EtlRunTable[]

  @@index([startedAt])
  @@map("etl_run")
  @@schema("platform")
}

// ─────────────────────────────────────────────────────────────────────────
// Utilities module — batch-change overlay + audit
//
// Module spec: docs/modules/utilities.md
// Design spec: docs/dev/specs/2026-04-21-utilities-batch-change-design.md
//
// Phase contract: writes land in `app.*`; legacy SKU identity stays a natural-key
// (`rics_sku_code`) soft reference only. No FK into transient import staging.
// ─────────────────────────────────────────────────────────────────────────

/// Replace-style overlay for singular SKU attributes. Sparse — only non-null columns override.
/// Read path: COALESCE(override.field, mirror.field) for each attribute.
/// Platform-owned append-only audit spine.
model PlatformAuditLog {
  id             String   @id @default(uuid())
  eventType      String   @map("event_type")
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String?  @map("resource_id")
  actorUserId    String?  @map("actor_user_id")
  actorSessionId String?  @map("actor_session_id")
  outcome        String   @default("SUCCESS")
  reason         String?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  beforeJson     Json?    @map("before_json")
  afterJson      Json?    @map("after_json")
  metadataJson   Json?    @map("metadata_json")
  traceId        String?  @map("trace_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([resourceType, resourceId, createdAt(sort: Desc)], map: "platform_audit_log_resource_idx")
  @@index([actorUserId, createdAt(sort: Desc)], map: "platform_audit_log_actor_idx")
  @@index([eventType, createdAt(sort: Desc)], map: "platform_audit_log_event_idx")
  @@index([traceId], map: "platform_audit_log_trace_idx")
  @@map("platform_audit_log")
  @@schema("platform")
}

model PlatformRequestTrace {
  id             String   @id @default(uuid())
  traceId        String   @map("trace_id")
  requestId      String   @map("request_id")
  method         String
  route          String?
  originalUrl    String   @map("original_url")
  statusCode     Int      @map("status_code")
  durationMs     Int      @map("duration_ms")
  actorUserId    String?  @map("actor_user_id")
  actorSessionId String?  @map("actor_session_id")
  errorCode      String?  @map("error_code")
  errorMessage   String?  @map("error_message")
  timingJson     Json     @default("[]") @map("timing_json")
  metadataJson   Json?    @map("metadata_json")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([traceId, createdAt(sort: Desc)], map: "platform_request_trace_trace_idx")
  @@index([requestId], map: "platform_request_trace_request_idx")
  @@index([route, createdAt(sort: Desc)], map: "platform_request_trace_route_idx")
  @@index([statusCode, createdAt(sort: Desc)], map: "platform_request_trace_status_idx")
  @@index([durationMs(sort: Desc), createdAt(sort: Desc)], map: "platform_request_trace_duration_idx")
  @@index([createdAt(sort: Desc)], map: "platform_request_trace_created_idx")
  @@map("platform_request_trace")
  @@schema("platform")
}

/// Manager review state for Activity Review. This intentionally lives outside
/// the append-only audit log so review workflow updates do not rewrite events.
model ActivityReviewEventReview {
  auditEventId     String   @id @map("audit_event_id")
  status           String
  reviewedByUserId String?  @map("reviewed_by_user_id")
  reviewNote       String?  @map("review_note")
  reviewedAt       DateTime @default(now()) @map("reviewed_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@index([status, reviewedAt(sort: Desc)], map: "activity_review_event_review_status_idx")
  @@index([reviewedByUserId, reviewedAt(sort: Desc)], map: "activity_review_event_review_reviewer_idx")
  @@map("activity_review_event_review")
  @@schema("platform")
}

/// Replace-style overlay for singular SKU attributes.
model SkuAttributeOverride {
  ricsSkuCode String   @id @map("rics_sku_code") @db.VarChar(15)
  category    Int?
  vendor      String?  @db.VarChar(10)
  season      String?  @db.VarChar(2)
  groupCode   String?  @map("group_code") @db.VarChar(10)
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String   @map("updated_by")

  @@index([category])
  @@index([vendor])
  @@index([season])
  @@index([groupCode])
  @@map("sku_attribute_override")
  @@schema("app")
}

/// Vendor write-surface overlay. Replaces the MDB write path that was removed
/// 2026-04-23. Single table with a `source` discriminator:
///   - 'native'    = vendor born in Postgres (no imported legacy twin)
///   - 'override'  = sparse per-column override of an imported legacy vendor
///                   (null → fall back to baseline; non-null → override)
///   - 'tombstone' = hide an imported legacy vendor from reads
///
/// Natural-key only — the 4-char RICS code.
model VendorOverlay {
  code   String @id @db.VarChar(4)
  /// 'native' | 'override' | 'tombstone' — CHECK constraint on the column.
  source String @db.VarChar(10)

  // Vendor value columns (nullable — used only when non-null per source semantics)
  shortName     String?  @map("short_name")
  mailName      String?  @map("mail_name")
  addr1         String?
  addr2         String?
  city          String?
  state         String?
  zip           String?
  phone         String?
  fax           String?
  contact       String?
  terms         String?
  shipInst      String?  @map("ship_inst")
  comment       String?
  manuCode      String?  @map("manu_code")
  manuName      String?  @map("manu_name")
  qualifierId   String?  @map("qualifier_id")
  qualifierCode String?  @map("qualifier_code")
  colorCode     Boolean? @map("color_code")
  longComment   String?  @map("long_comment")
  eMail         String?  @map("e_mail")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  @@index([source])
  @@map("vendor_overlay")
