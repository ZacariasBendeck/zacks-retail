# Zack's Retail API — Environment Variables
# Copy this file to .env and fill in the values.

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000

# ── Postgres (net-new storefront data: cart, orders, content overlay) ─────
# Matches the docker-compose.yml service. Port 5433 is exposed to avoid
# colliding with a native Postgres install.
DATABASE_URL=postgresql://zacks:zacks_dev@localhost:5433/zacks_retail?schema=public

# ── Storefront product source ─────────────────────────────────────────────
# rics  → live read-through to the legacy RICS MDBs (default in dev)
# local → legacy SQLite path in apps/api/data/inventory.db (kept for regression comparison)
PRODUCT_SOURCE=rics

# ── Inventory module source ───────────────────────────────────────────────
# rics  → live read-through to RIINVQUA / RIINVMAS / RISIZE / RISTORE for the
#         Inventory Inquiry, Find-by-Size, and Inventory Detail Report screens.
# local → not yet implemented; reserved for the eventual Postgres-backed path.
INVENTORY_SOURCE=rics

# ── Sales-reporting module source ─────────────────────────────────────────
# rics  → live read-through to RITRNSSV / RISTORE / RISLSPSN for the
#         sales-reporting module (Sales by Day/Time/SKU, Salesperson Summary,
#         Sales Analysis, Best Sellers, Stock Status).
# local → not yet implemented; the facade returns HTTP 501 until a local
#         Postgres sales warehouse is built.
SALES_SOURCE=rics

# Secret used to sign the anonymous cart session cookie.
SESSION_COOKIE_SECRET=change-me-in-production

# ── AI Image Analysis ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── RICS Access MDB reads (storefront product adapter + sales reports) ────
# Defaults resolve to <repo>/Rics Databases/<FILE>. Override only if the
# databases live somewhere else on your machine.
RICS_DB_DIR=
RICS_MDB_PASSWORD=
RICS_SALES_DB_FILE=RITRNSSV.MDB
RICS_STORE_DB_FILE=RISTORE.MDB
RICS_INVMAS_DB_FILE=RIINVMAS.MDB
RICS_CATEG_DB_FILE=RICATEG.MDB
RICS_DEPT_DB_FILE=RIDEPT.MDB
RICS_VENDOR_DB_FILE=RIVENDOR.MDB
RICS_SIZE_DB_FILE=RISIZE.MDB
RICS_UPC_DB_FILE=RIUPC.MDB
RICS_INVQUA_DB_FILE=RIINVQUA.MDB
RICS_INVCHG_DB_FILE=RIINVCHG.MDB
RICS_SLSPSN_DB_FILE=RISLSPSN.MDB
RICS_TAX_DB_FILE=RITAX.MDB
RICS_MAIL_DB_FILE=RIMAIL.MDB
RICS_ARACCT_DB_FILE=RIARACCT.MDB
RICS_GIFTCT_DB_FILE=RIGIFTCT.MDB
RICS_PODET_DB_FILE=RIPODET.MDB

# RICS product images folder on the RICS host machine. The files here are named
# exactly as referenced in InventoryMaster.PictureFileName (e.g. DMTDU1BK.jpg).
# Served by the API at /rics-images/<filename>. Leave blank to use the default.
RICS_IMAGES_DIR=C:/RICSWIN/ricspics

# Storefront catalog scope — the live adapter only surfaces SKUs whose Season
# and Category match these filters. Defaults target shoes (RICS categories
# 556–599) for the current selling season.
RICS_STOREFRONT_SEASON=A
RICS_STOREFRONT_CATEGORY_MIN=556
RICS_STOREFRONT_CATEGORY_MAX=599
