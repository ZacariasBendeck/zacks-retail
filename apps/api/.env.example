# Benlow RICS API — Environment Variables
# Copy this file to .env and fill in the values.

# Server
PORT=4000

# AI Image Analysis (required for "Fill with AI" feature)
ANTHROPIC_API_KEY=sk-ant-...

# Odoo REST API (for storefront BFF)
ODOO_URL=http://localhost:8069
ODOO_API_BASE=/rics-storefront-api
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=admin
