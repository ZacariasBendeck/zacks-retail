    "db:verify:migration011": "npx tsx --experimental-sqlite scripts/verifyMigration011.ts",
    "db:verify:migration014": "npx tsx --experimental-sqlite scripts/verifyMigration014.ts",
    "db:verify:migration015": "npx tsx --experimental-sqlite scripts/verifyMigration015.ts",
    "db:verify:migration016": "npx tsx --experimental-sqlite scripts/verifyMigration016.ts",
