{
  "name": "@benlow-rics/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file-if-exists=.env --experimental-sqlite --watch-path=src --watch-path=prisma -r tsx/cjs src/index.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env --experimental-sqlite dist/index.js",
    "seed": "npx tsx --experimental-sqlite scripts/seeds/seed.ts",
    "test": "NODE_OPTIONS=--experimental-sqlite npx jest --forceExit --detectOpenHandles",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "migrate:new": "node -r tsx/cjs scripts/migrations/migrate-new.ts",
    "migrate:lint": "node -r tsx/cjs scripts/migrations/migrate-lint.ts",
    "bootstrap:app-data": "node --env-file-if-exists=.env -r tsx/cjs scripts/bootstrap-app-data.ts",
    "rics:discover": "tsx scripts/rics/discovery/discover-rics-schema.ts",
    "rics:convert": "tsx scripts/rics/sync/convert-rics-mdbs.ts",
    "sync:rics": "node --env-file-if-exists=.env -r tsx/cjs scripts/rics/sync/sync-rics.ts",
    "sync:rics-skus": "node --env-file-if-exists=.env -r tsx/cjs scripts/rics/sync/sync-rics-skus.ts",
    "verify:rics-mirror": "node --env-file-if-exists=.env -r tsx/cjs scripts/rics/verify/verify-rics-mirror.ts",
    "test:sku-writeback": "node --env-file-if-exists=.env -r tsx/cjs scripts/dangerous/legacy-writeback/test-sku-writeback.ts",
    "export:attributes": "node --env-file-if-exists=.env -r tsx/cjs scripts/catalog/export-attribute-catalog.ts",
    "import:attributes": "node --env-file-if-exists=.env -r tsx/cjs scripts/catalog/import-attribute-catalog.ts",
    "seed:sku-attributes": "node --env-file-if-exists=.env -r tsx/cjs scripts/seeds/seed-sku-attributes.ts",
    "seed:product-families": "node --env-file-if-exists=.env -r tsx/cjs scripts/seeds/seed-product-families.ts",
    "seed:legacy-ref-dimensions": "node --env-file-if-exists=.env -r tsx/cjs scripts/seeds/seed-legacy-ref-dimensions.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "axios": "^1.14.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
