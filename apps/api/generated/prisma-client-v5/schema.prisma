  nonTaxable        Boolean                      @default(false) @map("non_taxable")
  planNum           Int?                         @map("plan_num") @db.SmallInt
  planCount         Int?                         @map("plan_count") @db.SmallInt
  planDollars       Decimal?                     @map("plan_dollars") @db.Decimal(18, 4)
  planLastCreditAt  DateTime?                    @map("plan_last_credit_at") @db.Timestamptz(6)
  planCreditBalance Decimal?                     @map("plan_credit_balance") @db.Decimal(18, 4)
  createdAt         DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("customer_financial_profile")
  @@schema("app")
}

