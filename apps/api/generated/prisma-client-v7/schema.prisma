  status               String                      @default("active")
  source               String                      @default("rics_csv")
  firstSeenAt          DateTime?                   @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt           DateTime?                   @map("last_seen_at") @db.Timestamptz(6)
  importedFromBatchId  String?                     @map("imported_from_batch_id") @db.Uuid
  importedFromBatch    CustomerImportBatch?        @relation(fields: [importedFromBatchId], references: [id], onDelete: SetNull)
  ricsAccount          String?                     @unique @map("rics_account")
  ricsCode             String?                     @unique @map("rics_code")
  ricsDateAdded        DateTime?                   @map("rics_date_added") @db.Timestamptz(6)
  ricsDateLastChanged  DateTime?                   @map("rics_date_last_changed") @db.Timestamptz(6)
  createdAt            DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  identities           CustomerIdentity[]
  contacts             CustomerContact[]
  addresses            CustomerAddress[]
  legacyProfile        CustomerLegacyProfile?
  financialProfile     CustomerFinancialProfile?
  salesSummaryLegacy   CustomerSalesSummaryLegacy?
  transactionFacts     CustomerTransactionFact[]
  salesHistoryTickets  SalesHistoryTicket[]        @relation("CustomerSalesHistoryTickets")
  metrics              CustomerMetrics?
  metricSnapshots      CustomerMetricsDaily[]

  @@index([importedFromBatchId], map: "customer_imported_from_batch_idx")
  @@map("customer")
  @@schema("app")
}

