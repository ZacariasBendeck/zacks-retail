// Zack's Retail — API Prisma schema.
//
// Scope: Postgres-backed application tables for storefront, admin,
// product/catalog, reporting, and operational workflows.
//
// PostgreSQL is the system of record for all net-new application data.
// SQLite remains only as a frozen read-store for legacy admin reference tables
// such as ref_colors, ref_patterns, and related dimensions while they are
// migrated piecewise into app.* Postgres dimensions.
//
// Legacy RICS v7.7 Access MDB files are read only through offline extract
// tooling that produces CSV artifact packs for direct Postgres imports:
//
//   RICS MDB → PowerShell/C# ACE.OLEDB export → CSV artifact pack → app/module imports
//
// The API must not read directly from or write to RICS MDB files.
// The API must not create new SQLite writes.
//
// RICS SKU codes are treated as opaque external string keys.
// Module specs in docs/modules/*.md are governed contracts and should stay
// aligned with this schema.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

generator apiClient {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../generated/prisma-client-v7"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "platform", "app"]
}

/// Web-only overlay keyed by RICS SKU code.
/// Fields here override or extend what RICS carries (description, imagery, SEO).
/// A product with no row here still renders — it just uses RICS fields only.
model ProductContent {
  ricsSkuCode    String   @id
  webDescription String?
  heroImageUrl   String?
  galleryJson    Json?
  specsJson      Json?
  seoSlug        String?  @unique
  published      Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@schema("public")
}

/// Anonymous cart keyed by a session cookie (UUID). User accounts come later.
model Cart {
  id        String     @id @default(uuid())
  sessionId String     @unique
  lines     CartLine[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@schema("public")
}

model CartLine {
  id                String   @id @default(uuid())
  cartId            String
  cart              Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  ricsSkuCode       String
  sizeLabel         String
  colorId           Int?
  quantity          Int
  unitPriceSnapshot Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())

  @@index([cartId])
  @@index([ricsSkuCode])
  @@schema("public")
}

model Order {
  id            String      @id @default(uuid())
  status        String      @default("PLACED")
  shippingJson  Json
  paymentMethod String
  subtotal      Decimal     @db.Decimal(12, 2)
  tax           Decimal     @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  lines         OrderLine[]
  createdAt     DateTime    @default(now())

  @@schema("public")
}

model OrderLine {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ricsSkuCode String
  sizeLabel   String
  colorId     Int?
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@schema("public")
}

model User {
  id                   String                       @id @default(uuid())
  email                String                       @unique
  passwordHash         String
  displayName          String
  active               Boolean                      @default(true)
  isEmployee           Boolean                      @default(false)
  ricsUserId           String?
  salespersonCode      String?
  otherInformation     String?
  commissionRate       Decimal?                     @db.Decimal(5, 2)
  commissionBase       String                       @default("NET_SALES")
  homeStoreId          String?
  hireDate             DateTime?
  terminatedAt         DateTime?
  timeClockEnabled     Boolean                      @default(true)
  timeClockPinHash     String?
  roleId               String
  role                 Role                         @relation(fields: [roleId], references: [id])
  sessions             Session[]
  salesPasswords       EmployeeSalesPassword[]      @relation("EmployeeSalesPasswords")
  salesPasswordAudits  EmployeeSalesPasswordAudit[] @relation("EmployeeSalesPasswordAuditEmployee")
  salesOverrideTokens  EmployeeSalesOverrideToken[] @relation("EmployeeSalesOverrideTokens")
  commissionOverrides  CommissionOverride[]
  timeClockEntries     TimeClockEntry[]             @relation("EmployeeTimeClockEntries")
  ownedReportTemplates ReportTemplate[]             @relation("OwnedReportTemplates")
  reportRuns           ReportRun[]                  @relation("ReportRuns")
  lastLoginAt          DateTime?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([roleId])
  @@index([isEmployee, active])
  @@index([salespersonCode])
  @@schema("public")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions String[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@schema("public")
}

model EmployeeSalesPassword {
  id                           String                       @id @default(uuid())
  employeeId                   String
  employee                     User                         @relation("EmployeeSalesPasswords", fields: [employeeId], references: [id], onDelete: Cascade)
  pinHash                      String
  scopes                       String[]
  active                       Boolean                      @default(true)
  failedAttempts               Int                          @default(0)
  failedAttemptWindowStartedAt DateTime?
  dailyFailedCount             Int                          @default(0)
  dailyFailedWindowStartedAt   DateTime?
  lockedUntil                  DateTime?
  revokedAt                    DateTime?
  issuedByUserId               String
  updatedByUserId              String?
  audits                       EmployeeSalesPasswordAudit[]
  overrideTokens               EmployeeSalesOverrideToken[]
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt

  @@index([employeeId, active])
  @@index([lockedUntil])
  @@schema("public")
}

model EmployeeSalesPasswordAudit {
  id             String                 @id @default(uuid())
  employeeId     String
  employee       User                   @relation("EmployeeSalesPasswordAuditEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  passwordId     String?
  password       EmployeeSalesPassword? @relation(fields: [passwordId], references: [id], onDelete: SetNull)
  scope          String
  outcome        String
  invokingUserId String?
  ticketId       String?
  action         String?
  ipAddress      String?
  createdAt      DateTime               @default(now())

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([scope, createdAt(sort: Desc)])
  @@schema("public")
}

model EmployeeSalesOverrideToken {
  id             String                @id @default(uuid())
  passwordId     String
  password       EmployeeSalesPassword @relation(fields: [passwordId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       User                  @relation("EmployeeSalesOverrideTokens", fields: [employeeId], references: [id], onDelete: Cascade)
  scope          String
  tokenHash      String                @unique
  ticketId       String?
  action         String?
  invokingUserId String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime              @default(now())

  @@index([employeeId, scope, expiresAt])
  @@index([consumedAt])
  @@schema("public")
}

model TimeClockPolicy {
  storeId                  Int      @id
  enabled                  Boolean  @default(false)
  requireClockInBeforeSale Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@schema("public")
}

model TimeClockEntry {
  id                 String                     @id @default(uuid())
  employeeId         String
  employee           User                       @relation("EmployeeTimeClockEntries", fields: [employeeId], references: [id], onDelete: Cascade)
  storeId            Int
  clockedInAt        DateTime
  clockedOutAt       DateTime?
  nonSales           Boolean                    @default(false)
  clockedInByUserId  String
  clockedOutByUserId String?
  autoClosedAtCap    Boolean                    @default(false)
  note               String?
  adjustments        TimeClockEntryAdjustment[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([employeeId, clockedOutAt])
  @@index([storeId, clockedOutAt])
  @@index([clockedInAt])
  @@schema("public")
}

model TimeClockEntryAdjustment {
  id                      String         @id @default(uuid())
  timeClockEntryId        String
  timeClockEntry          TimeClockEntry @relation(fields: [timeClockEntryId], references: [id], onDelete: Cascade)
  employeeId              String
  actedByUserId           String
  reason                  String
  previousStoreId         Int
  nextStoreId             Int
  previousClockedInAt     DateTime
  nextClockedInAt         DateTime
  previousClockedOutAt    DateTime?
  nextClockedOutAt        DateTime?
  previousNonSales        Boolean
  nextNonSales            Boolean
  previousAutoClosedAtCap Boolean
  nextAutoClosedAtCap     Boolean
  previousNote            String?
  nextNote                String?
  createdAt               DateTime       @default(now())

  @@index([timeClockEntryId, createdAt(sort: Desc)])
  @@index([employeeId, createdAt(sort: Desc)])
  @@schema("public")
}

enum CommissionOverrideScope {
  SKU
  CATEGORY
  DEPARTMENT

  @@schema("public")
}

model CommissionOverride {
  id              String                  @id @default(uuid())
  employeeId      String
  employee        User                    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  scope           CommissionOverrideScope
  skuId           String?
  categoryId      String?
  departmentId    String?
  rate            Decimal                 @db.Decimal(5, 2)
  effectiveFrom   DateTime                @default(now())
  effectiveTo     DateTime?
  createdByUserId String
  updatedByUserId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([employeeId, scope])
  @@index([effectiveFrom, effectiveTo])
  @@schema("public")
}

/// Phase 1 audit log for products-module mutations against the live RICS MDBs.
/// Every create/update/delete on a taxonomy entity (Department, Category,
/// Sector, Group, Keyword, PromotionCode, SizeType) or a future products write
/// path (SKU, Vendor, Price Change, UPC) writes one row here. The audit log is
/// observability — product correctness depends on the Access write succeeding,
/// not on this row being present. Writers should treat Postgres failures as
/// non-blocking and log them.
///
/// Retention is unbounded in Phase 1; Phase 2 will add a retention policy.
model ProductsAuditLog {
  id          String   @id @default(uuid())
  actor       String // user id, email, or "system" for scheduled-job writes
  action      String // e.g. "department.create", "sizeType.update"
  targetTable String // RICS table, e.g. "RIDEPT.Departments"
  targetPk    String // primary-key value as a string (numbers stringified)
  payloadJson Json // before/after snapshot for the mutation
  occurredAt  DateTime @default(now())

  @@index([occurredAt])
  @@index([targetTable, targetPk])
  @@schema("public")
}

/// Season descriptions — user-defined taxonomy tags assigned to SKUs.
///
/// Clarified 2026-04-19: Seasons are a simple user-editable attribute on
/// SKUs, just like Groups or Categories. The user picks any code + description
/// that fits their reporting workflow — no fixed code universe, no computed
/// "current season" based on dates (that concept was a misread of RICS
/// Company Setup → Season Ending Months, which is only a reporting-date
/// filter, NOT a constraint on the seasons themselves).
///
/// RICS stores these in RISEMF.MDB (p. 218, Season Setup). This customer's
/// copy of that file does not open with ACE.OLEDB.12.0, so we mirror the
/// descriptions in Postgres. SKU counts still come from
/// InventoryMaster.Season via the Access read path.
model SeasonOverlay {
  code            String   @id @db.VarChar(2)
  description     String   @db.VarChar(32)
  dateLastChanged DateTime @default(now()) @updatedAt

  @@schema("public")
}

/// One row per RICS reload. Written by the `pnpm sync:rics` CLI.
model EtlRun {
  id         String        @id @default(uuid())
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  status     String // "running" | "ok" | "failed"
  totalRows  BigInt        @default(0)
  tableCount Int           @default(0)
  errorText  String?
  tables     EtlRunTable[]

  @@index([startedAt])
  @@map("etl_run")
  @@schema("platform")
}

// ─────────────────────────────────────────────────────────────────────────
// Utilities module — batch-change overlay + audit
//
// Module spec: docs/modules/utilities.md
// Design spec: docs/dev/specs/2026-04-21-utilities-batch-change-design.md
//
// Phase contract: writes land in `app.*`; legacy SKU identity stays a natural-key
// (`rics_sku_code`) soft reference only. No FK into transient import staging.
// ─────────────────────────────────────────────────────────────────────────

/// Replace-style overlay for singular SKU attributes. Sparse — only non-null columns override.
/// Read path: COALESCE(override.field, mirror.field) for each attribute.
model SkuAttributeOverride {
  ricsSkuCode String   @id @map("rics_sku_code") @db.VarChar(15)
  category    Int?
  vendor      String?  @db.VarChar(10)
  season      String?  @db.VarChar(2)
  groupCode   String?  @map("group_code") @db.VarChar(10)
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String   @map("updated_by")

  @@index([category])
  @@index([vendor])
  @@index([season])
  @@index([groupCode])
  @@map("sku_attribute_override")
  @@schema("app")
}

/// Vendor write-surface overlay. Replaces the MDB write path that was removed
/// 2026-04-23. Single table with a `source` discriminator:
///   - 'native'    = vendor born in Postgres (no imported legacy twin)
///   - 'override'  = sparse per-column override of an imported legacy vendor
///                   (null → fall back to baseline; non-null → override)
///   - 'tombstone' = hide an imported legacy vendor from reads
///
/// Natural-key only — the 4-char RICS code.
model VendorOverlay {
  code   String @id @db.VarChar(4)
  /// 'native' | 'override' | 'tombstone' — CHECK constraint on the column.
  source String @db.VarChar(10)

  // Vendor value columns (nullable — used only when non-null per source semantics)
  shortName     String?  @map("short_name")
  mailName      String?  @map("mail_name")
  addr1         String?
  addr2         String?
  city          String?
  state         String?
  zip           String?
  phone         String?
  fax           String?
  contact       String?
  terms         String?
  shipInst      String?  @map("ship_inst")
  comment       String?
  manuCode      String?  @map("manu_code")
  manuName      String?  @map("manu_name")
  qualifierId   String?  @map("qualifier_id")
  qualifierCode String?  @map("qualifier_code")
  colorCode     Boolean? @map("color_code")
  longComment   String?  @map("long_comment")
  eMail         String?  @map("e_mail")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  @@index([source])
  @@map("vendor_overlay")
  @@schema("app")
}

/// App-owned imported vendor baseline. Seeded from direct CSV import and read
/// together with VendorOverlay.
model Vendor {
  code            String               @id @db.VarChar(4)
  shortName       String               @map("short_name")
  mailName        String               @map("mail_name")
  addr1           String?
  addr2           String?
  city            String?
  state           String?
  zip             String?
  phone           String?
  fax             String?
  contact         String?
  terms           String?
  shipInst        String?              @map("ship_inst")
  comment         String?
  manuCode        String?              @map("manu_code")
  manuName        String?              @map("manu_name")
  qualifierId     String?              @map("qualifier_id")
  qualifierCode   String?              @map("qualifier_code")
  colorCode       Boolean              @default(false) @map("color_code")
  longComment     String?              @map("long_comment")
  eMail           String?              @map("e_mail")
  dateLastChanged DateTime?            @map("date_last_changed")
  storeAccounts   VendorStoreAccount[]

  @@map("vendor")
  @@schema("app")
}

/// Per-store vendor account numbers imported from the legacy CSV baseline.
model VendorStoreAccount {
  vendorCode      String    @map("vendor_code") @db.VarChar(4)
  vendor          Vendor    @relation(fields: [vendorCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  storeId         Int       @map("store_id") @db.SmallInt
  account         String    @default("")
  dateLastChanged DateTime? @map("date_last_changed")

  @@id([vendorCode, storeId])
  @@index([storeId], map: "vendor_store_account_store_id_idx")
  @@map("vendor_store_account")
  @@schema("app")
}

/// App-owned imported baseline for RICS StoreMaster. Core fields stay typed;
/// the rest of the wide legacy row is preserved under rawJson.
model StoreMaster {
  number          Int       @id @db.SmallInt
  description     String    @map("desc")
  mailName        String?   @map("mail_name")
  addr1           String?
  addr2           String?
  city            String?
  state           String?
  zip             String?
  eMail           String?   @map("e_mail")
  phone           String?
  fax             String?
  lastTicket      Int?      @map("last_ticket")
  billMailName    String?   @map("bill_mail_name")
  billAddr1       String?   @map("bill_addr1")
  billAddr2       String?   @map("bill_addr2")
  billCity        String?   @map("bill_city")
  billState       String?   @map("bill_state")
  billZip         String?   @map("bill_zip")
  otherChargeDesc String?   @map("other_charge_desc")
  region          Int?      @db.SmallInt
  dateLastChanged DateTime? @map("date_last_changed")
  rawJson         Json      @map("raw_json")

  @@map("store_master")
  @@schema("app")
}

/// App-owned UPC cross-reference. Imported legacy rows use source=RICS_IMPORT;
/// future manual/generated UPCs can coexist without a raw legacy landing schema.
model SkuUpc {
  upc              String    @id @db.VarChar(16)
  skuCode          String    @map("sku_code") @db.VarChar(15)
  skuId            String?   @map("sku_id") @db.Uuid
  sku              Sku?      @relation(fields: [skuId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  columnLabel      String    @default("") @map("column_label")
  rowLabel         String    @default("") @map("row_label")
  source           String    @default("RICS_IMPORT")
  vendorSku        String?   @map("vendor_sku")
  nrmaCode         String?   @map("nrma_code")
  status           String?   @db.Char(1)
  legacyPrefix     String?   @map("legacy_prefix")
  legacyNumber     String?   @map("legacy_number")
  legacyCheckDigit String?   @map("legacy_check_digit")
  dateLastChanged  DateTime? @map("date_last_changed")

  @@index([skuCode], map: "sku_upc_sku_code_idx")
  @@index([skuId], map: "sku_upc_sku_id_idx")
  @@index([vendorSku], map: "sku_upc_vendor_sku_idx")
  @@map("sku_upc")
  @@schema("app")
}

/// Case-pack header imported from RICS Case_Packs and used by purchasing /
/// manual receipt / return size-grid autofill.
model CasePack {
  code            String         @id @db.VarChar(6)
  description     String         @map("desc")
  sizeTypeCode    Int            @map("size_type_code") @db.SmallInt
  active          Boolean        @default(true)
  dateLastChanged DateTime?      @map("date_last_changed")
  cells           CasePackCell[]

  @@index([sizeTypeCode], map: "case_pack_size_type_code_idx")
  @@map("case_pack")
  @@schema("app")
}

/// One quantity per size-grid cell within a CasePack.
model CasePackCell {
  casePackCode String   @map("case_pack_code") @db.VarChar(6)
  casePack     CasePack @relation(fields: [casePackCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  columnLabel  String   @map("column_label")
  rowLabel     String   @default("") @map("row_label")
  quantity     Int

  @@id([casePackCode, columnLabel, rowLabel])
  @@index([casePackCode], map: "case_pack_cell_case_pack_code_idx")
  @@map("case_pack_cell")
  @@schema("app")
}

/// Imported legacy future-dated price change rows from RIFUTURE.MDB.
/// This is a baseline import surface, not yet the full scheduled-price engine.
model FuturePriceChange {
  id               String    @id @default(uuid()) @db.Uuid
  importKey        String    @unique(map: "future_price_change_import_key") @map("import_key")
  skuCode          String    @map("sku_code") @db.VarChar(15)
  skuId            String?   @map("sku_id") @db.Uuid
  sku              Sku?      @relation(fields: [skuId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  storeId          Int       @map("store_id") @db.SmallInt
  effectiveAt      DateTime  @map("effective_at")
  changeMaster     Boolean   @default(false) @map("change_master")
  revert           Boolean   @default(false)
  listPrice        Decimal?  @map("list_price") @db.Decimal(12, 2)
  retailPrice      Decimal?  @map("retail_price") @db.Decimal(12, 2)
  markDownPrice1   Decimal?  @map("mark_down_price1") @db.Decimal(12, 2)
  markDownPrice2   Decimal?  @map("mark_down_price2") @db.Decimal(12, 2)
  currentPriceSlot String?   @map("current_price_slot")
  overSizeAmount   Decimal?  @map("over_size_amount") @db.Decimal(12, 2)
  perks            Decimal?  @db.Decimal(12, 2)
  source           String    @default("RICS_IMPORT")
  dateLastChanged  DateTime? @map("date_last_changed")

  @@index([skuCode, effectiveAt], map: "future_price_change_sku_effective_at_idx")
  @@index([storeId, effectiveAt], map: "future_price_change_store_effective_at_idx")
  @@map("future_price_change")
  @@schema("app")
}

/// Imported legacy purchase-order headers from RIPOMAS.MDB. Preserves the
/// source rowset in Postgres until the full purchasing schema is promoted.
model PurchaseOrderLegacy {
  poNumber        String                    @id @map("po_number")
  billStore       Int?                      @map("bill_store") @db.SmallInt
  shipStore       Int?                      @map("ship_store") @db.SmallInt
  vendorCode      String?                   @map("vendor_code")
  confirmation    String?
  account         String?
  terms           String?
  shipVia         String?                   @map("ship_via")
  backOrder       Boolean                   @default(false) @map("back_order")
  splitShipment   Boolean                   @default(false) @map("split_shipment")
  orderDate       DateTime?                 @map("order_date")
  dueDate         DateTime?                 @map("due_date")
  cancelDate      DateTime?                 @map("cancel_date")
  paymentDate     DateTime?                 @map("payment_date")
  lastReceivedAt  DateTime?                 @map("last_received_at")
  comment         String?
  exportFlag      Boolean                   @default(false) @map("export_flag")
  exportComment   String?                   @map("export_comment")
  orderType       String?                   @map("order_type")
  releaseDt       String?                   @map("release_dt")
  department      String?
  buyer           String?
  notBefore       DateTime?                 @map("not_before")
  notAfter        DateTime?                 @map("not_after")
  shipCode        String?                   @map("ship_code")
  carrier         String?
  termsPeriod     String?                   @map("terms_period")
  termsDay        String?                   @map("terms_day")
  current         Boolean?
  legacyStatus    String?                   @map("legacy_status")
  dateLastChanged DateTime?                 @map("date_last_changed")
  lines           PurchaseOrderLegacyLine[]

  @@index([vendorCode], map: "purchase_order_legacy_vendor_code_idx")
  @@index([shipStore, orderDate], map: "purchase_order_legacy_ship_store_order_date_idx")
  @@map("purchase_order_legacy")
  @@schema("app")
}

/// Imported legacy purchase-order detail rows with the 18-wide ordered /
/// received quantity segments packed into int[] arrays.
model PurchaseOrderLegacyLine {
  poNumber        String              @map("po_number")
  purchaseOrder   PurchaseOrderLegacy @relation(fields: [poNumber], references: [poNumber], onDelete: Cascade, onUpdate: Cascade)
  skuCode         String              @map("sku_code") @db.VarChar(15)
  skuId           String?             @map("sku_id") @db.Uuid
  sku             Sku?                @relation(fields: [skuId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rowLabel        String              @default("") @map("row_label")
  segment         Int                 @db.SmallInt
  orderedQtys     Int[]               @map("ordered_qtys")
  receivedQtys    Int[]               @map("received_qtys")
  cost            Decimal?            @db.Decimal(12, 2)
  vendorCode      String?             @map("vendor_code")
  casePackCode    String?             @map("case_pack_code")
  caseMultiplier  Int?                @map("case_multiplier") @db.SmallInt
  dateLastChanged DateTime?           @map("date_last_changed")

  @@id([poNumber, skuCode, rowLabel, segment])
  @@index([skuCode], map: "purchase_order_legacy_line_sku_code_idx")
  @@index([skuId], map: "purchase_order_legacy_line_sku_id_idx")
  @@map("purchase_order_legacy_line")
  @@schema("app")
}

/// Imported legacy ASN carton headers from RICS ASN tables.
model AsnCartonLegacy {
  cartonNumber    String                @map("carton_number")
  poNumber        String                @map("po_number")
  receivedAt      DateTime?             @map("received_at")
  status          String?
  dateLastChanged DateTime?             @map("date_last_changed")
  lines           AsnCartonLegacyLine[]

  @@id([cartonNumber, poNumber])
  @@index([poNumber], map: "asn_carton_legacy_po_number_idx")
  @@map("asn_carton_legacy")
  @@schema("app")
}

/// Imported legacy ASN carton detail rows.
model AsnCartonLegacyLine {
  cartonNumber    String          @map("carton_number")
  poNumber        String          @map("po_number")
  carton          AsnCartonLegacy @relation(fields: [cartonNumber, poNumber], references: [cartonNumber, poNumber], onDelete: Cascade, onUpdate: Cascade)
  upc             String
  quantity        Int             @map("quantity") @db.SmallInt
  dateLastChanged DateTime?       @map("date_last_changed")

  @@id([cartonNumber, poNumber, upc])
  @@index([poNumber], map: "asn_carton_legacy_line_po_number_idx")
  @@map("asn_carton_legacy_line")
  @@schema("app")
}

/// Imported summary-only transfer history from RITRANSF.MDB. This preserves
/// the available legacy transfer totals without forcing them into the live
/// app.transfer document model, which requires line detail the source table
/// does not carry.
model TransferLegacySummary {
  id            String   @id @default(uuid()) @db.Uuid
  importKey     String   @unique(map: "transfer_legacy_summary_import_key") @map("import_key")
  fromStoreId   Int      @map("from_store_id") @db.SmallInt
  legacyType    String   @map("legacy_type")
  toStoreId     Int      @map("to_store_id") @db.SmallInt
  transferredAt DateTime @map("transferred_at")
  quantity      Int
  amount        Decimal? @db.Decimal(12, 2)

  @@index([fromStoreId, transferredAt], map: "transfer_legacy_summary_from_store_idx")
  @@index([toStoreId, transferredAt], map: "transfer_legacy_summary_to_store_idx")
  @@map("transfer_legacy_summary")
  @@schema("app")
}

/// Add/remove overlay for keywords, layered on the RICS space-separated KeyWords string.
/// Effective keywords = (split mirror.key_words) ∪ ADD-overrides − REMOVE-overrides.
model SkuKeywordOverride {
  ricsSkuCode String   @map("rics_sku_code") @db.VarChar(15)
  keyword     String   @db.VarChar(10)
  action      String   @db.VarChar(8) // 'ADD' | 'REMOVE'
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String   @map("updated_by")

  @@id([ricsSkuCode, keyword])
  @@index([keyword, action])
  @@map("sku_keyword_override")
  @@schema("app")
}

/// Replace-style overlay for size-type taxonomy (columns/rows arrays).
/// Mirrors the legacy SizeTypes shape but lives in app for edits.
model SizeTypeOverride {
  code        Int      @id
  description String?  @db.VarChar(32)
  columnsJson Json?    @map("columns_json")
  rowsJson    Json?    @map("rows_json")
  maxColumns  Int?     @map("max_columns")
  maxRows     Int?     @map("max_rows")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String   @map("updated_by")

  @@map("size_type_override")
  @@schema("app")
}

/// Audit header for a batch-utility invocation.
model ProductsBatchOperation {
  id            String                       @id @default(uuid())
  actor         String
  operationType String                       @map("operation_type")
  criteriaJson  Json                         @map("criteria_json")
  changeJson    Json                         @map("change_json")
  affectedCount Int                          @map("affected_count")
  startedAt     DateTime                     @default(now()) @map("started_at")
  completedAt   DateTime?                    @map("completed_at")
  undoneAt      DateTime?                    @map("undone_at")
  items         ProductsBatchOperationItem[]

  @@index([startedAt])
  @@index([operationType, startedAt])
  @@map("products_batch_operation")
  @@schema("app")
}

/// Per-SKU before/after snapshot — the undo payload.
model ProductsBatchOperationItem {
  id          String                 @id @default(uuid())
  batchId     String                 @map("batch_id")
  batch       ProductsBatchOperation @relation(fields: [batchId], references: [id], onDelete: Cascade)
  ricsSkuCode String                 @map("rics_sku_code") @db.VarChar(15)
  beforeJson  Json?                  @map("before_json")
  afterJson   Json?                  @map("after_json")

  @@index([batchId])
  @@index([ricsSkuCode])
  @@map("products_batch_operation_item")
  @@schema("app")
}

// ─────────────────────────────────────────────────────────────────────────
// Product Family — named bundles of attribute dimensions, selected per SKU
// via the RICS category → family mapping.
//
// Spec: docs/dev/plans/http-localhost-3000-inventory-skus-new-i-piped-galaxy.md
//
// Category numbers remain soft references to the imported legacy category code.
// Unmapped categories surface via app.category_family_orphans (DB view).
// ─────────────────────────────────────────────────────────────────────────

/// One of the 11 named Product Families (zapatos, tops, vestidos, pantalones,
/// ropa_otros, jackets_outerwear, suits, carteras, cinturones, accesorios,
/// general). Seeded from seeds/product_families/families.csv.
model ProductFamily {
  code             String                  @id
  labelEs          String                  @map("label_es")
  descriptionEs    String?                 @map("description_es")
  sortOrder        Int                     @map("sort_order") @db.SmallInt
  createdAt        DateTime                @default(now()) @map("created_at")
  categoryMappings CategoryProductFamily[]
  attributeRules   AttributeFamilyRule[]
  skus             Sku[]

  @@index([sortOrder], map: "product_family_sort_order_idx")
  @@map("product_family")
  @@schema("app")
}

/// One row per RICS category mapping it to exactly one Product Family.
/// `category_number` soft-refs the imported legacy category code.
/// Seeded from seeds/product_families/category_mapping.csv.
model CategoryProductFamily {
  categoryNumber Int           @id @map("category_number")
  familyCode     String        @map("family_code")
  family         ProductFamily @relation(fields: [familyCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  updatedAt      DateTime      @updatedAt @map("updated_at")
  updatedBy      String        @default("seed") @map("updated_by")

  @@index([familyCode], map: "category_product_family_family_code_idx")
  @@map("category_product_family")
  @@schema("app")
}

// ─────────────────────────────────────────────────────────────────────────
// SKU lifecycle — net-new SKUs created in Zack's Retail.
//
// Spec: docs/dev/plans/http-localhost-3000-inventory-skus-new-i-piped-galaxy.md
//       §"Phase 5 — SKU lifecycle (DRAFT → ACTIVE → DISCONTINUED)"
//
// State machine:
//   DRAFT        — provisional_code set, final `code` NULL, all fields editable.
//                  Receipt into WH allowed; allocate/barcode/POS/ecommerce blocked.
//   ACTIVE       — finalize flipped the row. `code` populated, rename blocked,
//                  all downstream ops unlocked.
//   DISCONTINUED — merged-into-another-SKU or retired. Read-only.
//
// Legacy RICS SKUs are imported into `app.sku` as `source='rics'`. The write
// path is `app.sku` only.
// ─────────────────────────────────────────────────────────────────────────

/// A SKU created in Zack's Retail (net-new). Lifecycle-managed.
/// The `sku_code_matches_state` check constraint enforces:
///   state=DRAFT  → code IS NULL
///   state≠DRAFT  → code IS NOT NULL
/// The service layer owns the transitions (see skuLifecycleService).
model Sku {
  id              String  @id @default(uuid()) @db.Uuid
  provisionalCode String  @map("provisional_code") @db.VarChar(32)
  code            String? @unique(map: "sku_code_key") @db.VarChar(15)
  skuState        String  @default("DRAFT") @map("sku_state")

  familyCode     String?        @map("family_code")
  family         ProductFamily? @relation(fields: [familyCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  categoryNumber Int?           @map("category_number")
  vendorId       String?        @map("vendor_id")
  vendorSku      String?        @map("vendor_sku")
  brandId        Int?           @map("brand_id")

  descriptionRics String? @map("description_rics")
  descriptionWeb  String? @map("description_web")
  comment         String?
  keywords        String?

  listPrice        Decimal? @map("list_price") @db.Decimal(12, 2)
  retailPrice      Decimal? @map("retail_price") @db.Decimal(12, 2)
  markDownPrice1   Decimal? @map("mark_down_price1") @db.Decimal(12, 2)
  markDownPrice2   Decimal? @map("mark_down_price2") @db.Decimal(12, 2)
  currentCost      Decimal? @map("current_cost") @db.Decimal(12, 2)
  currentPriceSlot String?  @map("current_price_slot")

  sizeType        Int?     @map("size_type") @db.SmallInt
  style           String?
  styleColor      String?  @map("style_color")
  season          String?  @db.VarChar(2)
  location        String?
  labelCode       String?  @map("label_code")
  colorCode       String?  @map("color_code")
  groupCode       String?  @map("group_code")
  pictureFileName String?  @map("picture_file_name")
  manufacturer    String?
  coupon          Boolean  @default(false)
  orderMultiple   Int?     @map("order_multiple") @db.SmallInt
  orderUom        String?  @map("order_uom")
  perks           Decimal? @db.Decimal(12, 2)
  discountCode    String?  @map("discount_code")

  activatedAt    DateTime? @map("activated_at")
  activatedBy    String?   @map("activated_by")
  discontinuedAt DateTime? @map("discontinued_at")
  discontinuedBy String?   @map("discontinued_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  createdBy      String    @map("created_by")
  updatedAt      DateTime? @map("updated_at")

  /// Transitional — carries legacy form-attribute IDs (colorId, shoeTypeId, …).
  /// Phase 4 replaces this with proper dimension assignments.
  legacyAttrs Json? @map("legacy_attrs")

  /// Provenance: 'app' = operator-created via POST /sku-drafts. 'rics' =
  /// imported from legacy RICS CSV artifacts into `app.sku`.
  source           String    @default("app")
  ricsLastSyncedAt DateTime? @map("rics_last_synced_at")
  ricsStatus       String?   @map("rics_status") @db.Char(1)

  activity                  SkuActivity[]
  sizes                     SkuSize[]
  inventory                 Inventory[]
  auditLog                  InventoryAuditLog[]
  stockLevels               StockLevel[]
  stockMovements            StockMovement[]
  replenishmentTargets      ReplenishmentTarget[]
  inventorySalesCells       InventorySalesCell[]
  upcs                      SkuUpc[]
  futurePriceChanges        FuturePriceChange[]
  purchaseOrderLegacyLines  PurchaseOrderLegacyLine[]
  manualReceipts            ManualReceipt[]
  manualReturns             ManualReturn[]
  transferLines             TransferLine[]
  inventoryAdjustmentLines  InventoryAdjustmentLine[]
  inventoryHistorySnapshots InventoryHistorySnapshot[]

  @@unique([provisionalCode], map: "sku_provisional_code_key")
  @@index([skuState, familyCode], map: "sku_state_family_idx")
  @@index([vendorId], map: "sku_vendor_idx")
  @@index([categoryNumber], map: "sku_category_idx")
  @@index([createdAt], map: "sku_created_at_idx")
  @@index([source, skuState], map: "sku_source_state_idx")
  @@map("sku")
  @@schema("app")
}

/// State-transition audit log. Written by skuLifecycleService — no DB trigger,
/// because we want the service to own the who/why context (actor, reason).
model SkuActivity {
  id          String   @id @default(uuid()) @db.Uuid
  skuId       String   @map("sku_id") @db.Uuid
  sku         Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  event       String // 'created' | 'updated' | 'finalized' | 'discontinued' | 'reactivated'
  fromState   String?  @map("from_state")
  toState     String?  @map("to_state")
  actor       String
  payloadJson Json?    @map("payload_json")
  occurredAt  DateTime @default(now()) @map("occurred_at")

  @@index([skuId, occurredAt(sort: Desc)], map: "sku_activity_sku_id_idx")
  @@index([occurredAt(sort: Desc)], map: "sku_activity_occurred_at_idx")
  @@map("sku_activity")
  @@schema("app")
}

/// Per-SKU size-label rows. Each SKU carries an ordered list of the sizes it
/// is sold in (e.g. "7", "7.5", "8", ...). `sort_order` controls display on
/// the size grid; `active` hides a size from new assignments without dropping
/// inventory rows that reference it. Matches the pre-migration SQLite shape
/// 1:1 with native Postgres types.
model SkuSize {
  id        String              @id @default(uuid()) @db.Uuid
  skuId     String              @map("sku_id") @db.Uuid
  sku       Sku                 @relation(fields: [skuId], references: [id], onDelete: Cascade)
  sizeLabel String              @map("size_label")
  sortOrder Int                 @default(0) @map("sort_order")
  active    Boolean             @default(true)
  inventory Inventory[]
  auditLog  InventoryAuditLog[]

  @@unique([skuId, sizeLabel])
  @@index([skuId], map: "sku_size_sku_id_idx")
  @@map("sku_size")
  @@schema("app")
}

/// Per-(SKU × size) on-hand + reserved state. One row per size when the SKU
/// has a size grid; `sku_size_id = null` for SKUs that don't (accessories,
/// single-variant items). `(sku_id, sku_size_id)` is unique so the pair is
/// the natural join key for mutations from adjustmentService / ticketService.
model Inventory {
  id               String    @id @default(uuid()) @db.Uuid
  skuId            String    @map("sku_id") @db.Uuid
  sku              Sku       @relation(fields: [skuId], references: [id])
  skuSizeId        String?   @map("sku_size_id") @db.Uuid
  skuSize          SkuSize?  @relation(fields: [skuSizeId], references: [id])
  quantityOnHand   Int       @default(0) @map("quantity_on_hand")
  quantityReserved Int       @default(0) @map("quantity_reserved")
  lastCountedAt    DateTime? @map("last_counted_at")
  version          Int       @default(1)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([skuId, skuSizeId], map: "inventory_sku_size_unique")
  @@index([skuId], map: "inventory_sku_id_idx")
  @@map("inventory")
  @@schema("app")
}

/// Append-only trail of every quantity adjustment. Referenced by
/// adjustmentService, inventoryService, and admin reports ("who moved
/// stock when and why"). `resultingBalance` is the on-hand quantity
/// AFTER the adjustment applied — lets the audit UI render a ledger
/// without re-running the math.
model InventoryAuditLog {
  id                    String   @id @default(uuid()) @db.Uuid
  skuId                 String   @map("sku_id") @db.Uuid
  sku                   Sku      @relation(fields: [skuId], references: [id])
  skuSizeId             String?  @map("sku_size_id") @db.Uuid
  skuSize               SkuSize? @relation(fields: [skuSizeId], references: [id])
  adjustment            Int
  reason                String
  resultingBalance      Int      @map("resulting_balance")
  performedBy           String   @default("system") @map("performed_by")
  sourceDocumentRefType String?  @map("source_document_ref_type")
  sourceDocumentRefId   String?  @map("source_document_ref_id")
  idempotencyKey        String?  @unique(map: "inventory_audit_log_idempotency_key") @map("idempotency_key")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([skuId], map: "inventory_audit_log_sku_id_idx")
  @@index([createdAt], map: "inventory_audit_log_created_at_idx")
  @@index([sourceDocumentRefType, sourceDocumentRefId], map: "inventory_audit_log_source_ref_idx")
  @@map("inventory_audit_log")
  @@schema("app")
}

model InventoryAdjustment {
  id             String                    @id @default(uuid()) @db.Uuid
  type           String
  fromLocationId String?                   @map("from_location_id")
  toLocationId   String?                   @map("to_location_id")
  reason         String?
  createdBy      String                    @map("created_by")
  createdAt      DateTime                  @default(now()) @map("created_at")
  lines          InventoryAdjustmentLine[]

  @@index([type, createdAt(sort: Desc)], map: "inventory_adjustment_type_created_idx")
  @@index([createdAt(sort: Desc)], map: "inventory_adjustment_created_at_idx")
  @@map("inventory_adjustment")
  @@schema("app")
}

model InventoryAdjustmentLine {
  id           String              @id @default(uuid()) @db.Uuid
  adjustmentId String              @map("adjustment_id") @db.Uuid
  adjustment   InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  skuId        String              @map("sku_id") @db.Uuid
  sku          Sku                 @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  quantity     Int
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([adjustmentId, createdAt], map: "inventory_adjustment_line_adjustment_created_idx")
  @@index([skuId], map: "inventory_adjustment_line_sku_id_idx")
  @@map("inventory_adjustment_line")
  @@schema("app")
}

/// Store-aware stock projection keyed per (store × SKU × size-grid cell).
/// This is the additive surface for inventory-module writes that must not live
/// in SQLite.
model StockLevel {
  id             String    @id @default(uuid()) @db.Uuid
  storeId        Int       @map("store_id")
  skuId          String    @map("sku_id") @db.Uuid
  sku            Sku       @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  columnLabel    String    @default("") @map("column_label")
  rowLabel       String    @default("") @map("row_label")
  onHand         Int       @default(0) @map("on_hand")
  reserved       Int       @default(0)
  lastReceivedAt DateTime? @map("last_received_at")
  lastMovementAt DateTime? @map("last_movement_at")
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([storeId, skuId, columnLabel, rowLabel], map: "stock_level_store_sku_cell_key")
  @@index([skuId, storeId], map: "stock_level_sku_store_idx")
  @@index([storeId, onHand], map: "stock_level_store_on_hand_idx")
  @@map("stock_level")
  @@schema("app")
}

/// Append-only movement ledger for store-aware inventory operations.
model StockMovement {
  id                   String             @id @default(uuid()) @db.Uuid
  storeId              Int                @map("store_id")
  skuId                String             @map("sku_id") @db.Uuid
  sku                  Sku                @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  columnLabel          String             @default("") @map("column_label")
  rowLabel             String             @default("") @map("row_label")
  movementType         String             @map("movement_type")
  quantityDelta        Int                @map("quantity_delta")
  unitCostSnapshot     Decimal?           @map("unit_cost_snapshot") @db.Decimal(12, 2)
  retailPriceSnapshot  Decimal?           @map("retail_price_snapshot") @db.Decimal(12, 2)
  sourceDocumentType   String             @map("source_document_type")
  sourceDocumentId     String             @map("source_document_id")
  reasonCode           String?            @map("reason_code")
  comment              String?
  performedBy          String             @map("performed_by")
  movementAt           DateTime           @map("movement_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  idempotencyKey       String?            @unique(map: "stock_movement_idempotency_key") @map("idempotency_key")
  manualReceiptLine    ManualReceiptLine? @relation("ManualReceiptLineMovement")
  manualReturnLine     ManualReturnLine?  @relation("ManualReturnLineMovement")
  transferLineOutbound TransferLine[]     @relation("TransferLineOutboundMovement")
  transferLineInbound  TransferLine[]     @relation("TransferLineInboundMovement")

  @@index([skuId, storeId, movementAt(sort: Desc)], map: "stock_movement_sku_store_movement_at_idx")
  @@index([movementType, movementAt(sort: Desc)], map: "stock_movement_type_movement_at_idx")
  @@index([storeId, movementAt(sort: Desc)], map: "stock_movement_store_movement_at_idx")
  @@index([sourceDocumentType, sourceDocumentId], map: "stock_movement_source_document_idx")
  @@map("stock_movement")
  @@schema("app")
}

/// One saved "Enter Manual Receipts" document in the inventory module.
/// One document represents one SKU receipt into one store, with one or more
/// size-grid cell lines.
model ManualReceipt {
  id                   String              @id @default(uuid()) @db.Uuid
  storeId              Int                 @map("store_id")
  skuId                String              @map("sku_id") @db.Uuid
  sku                  Sku                 @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  performedBy          String              @map("performed_by")
  referenceNumber      String?             @map("reference_number")
  storeLabelsOnReceive Boolean             @default(false) @map("store_labels_on_receive")
  movementAt           DateTime            @map("movement_at")
  unitCostOverride     Decimal?            @map("unit_cost_override") @db.Decimal(12, 2)
  retailPriceOverride  Decimal?            @map("retail_price_override") @db.Decimal(12, 2)
  casePackId           String?             @map("case_pack_id")
  casePackMultiplier   Int?                @map("case_pack_multiplier")
  note                 String?
  idempotencyKey       String?             @unique(map: "manual_receipt_idempotency_key") @map("idempotency_key")
  createdAt            DateTime            @default(now()) @map("created_at")
  lines                ManualReceiptLine[]

  @@index([storeId, movementAt(sort: Desc)], map: "manual_receipt_store_movement_at_idx")
  @@index([skuId, movementAt(sort: Desc)], map: "manual_receipt_sku_movement_at_idx")
  @@map("manual_receipt")
  @@schema("app")
}

model ManualReceiptLine {
  id              String        @id @default(uuid()) @db.Uuid
  manualReceiptId String        @map("manual_receipt_id") @db.Uuid
  manualReceipt   ManualReceipt @relation(fields: [manualReceiptId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  columnLabel     String        @default("") @map("column_label")
  rowLabel        String        @default("") @map("row_label")
  quantity        Int
  unitCost        Decimal       @map("unit_cost") @db.Decimal(12, 2)
  retailPrice     Decimal       @map("retail_price") @db.Decimal(12, 2)
  movementId      String        @unique(map: "manual_receipt_line_movement_id_key") @map("movement_id") @db.Uuid
  movement        StockMovement @relation("ManualReceiptLineMovement", fields: [movementId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([manualReceiptId, columnLabel, rowLabel], map: "manual_receipt_line_cell_key")
  @@index([manualReceiptId], map: "manual_receipt_line_receipt_id_idx")
  @@map("manual_receipt_line")
  @@schema("app")
}

/// Per-cell replenishment target values used by Model / Max / Reorder editing
/// and by transfer / auto-PO recommendation flows.
model ReplenishmentTarget {
  id          String   @id @default(uuid()) @db.Uuid
  storeId     Int      @map("store_id")
  skuId       String   @map("sku_id") @db.Uuid
  sku         Sku      @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  columnLabel String   @default("") @map("column_label")
  rowLabel    String   @default("") @map("row_label")
  modelQty    Int?     @map("model_qty")
  maxQty      Int?     @map("max_qty")
  reorderQty  Int?     @map("reorder_qty")
  updatedBy   String   @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([storeId, skuId, columnLabel, rowLabel], map: "replenishment_target_store_sku_cell_key")
  @@index([skuId, storeId], map: "replenishment_target_sku_store_idx")
  @@index([storeId], map: "replenishment_target_store_idx")
  @@map("replenishment_target")
  @@schema("app")
}

/// Per-cell inquiry sales counters imported from `inventory_quantities.csv`.
/// These mirror the legacy MTD / STD / YTD / LY size-grid cells without
/// dragging `rics_mirror.inventory_quantities` back onto the request path.
model InventorySalesCell {
  id          String   @id @default(uuid()) @db.Uuid
  storeId     Int      @map("store_id")
  skuId       String   @map("sku_id") @db.Uuid
  sku         Sku      @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  columnLabel String   @default("") @map("column_label")
  rowLabel    String   @default("") @map("row_label")
  mtdSales    Int      @default(0) @map("mtd_sales")
  stdSales    Int      @default(0) @map("std_sales")
  ytdSales    Int      @default(0) @map("ytd_sales")
  lySales     Int      @default(0) @map("ly_sales")
  source      String   @default("RICS_IMPORT")
  sourceRunId String?  @map("source_run_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
